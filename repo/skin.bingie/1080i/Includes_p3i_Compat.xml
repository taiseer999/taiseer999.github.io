<?xml version="1.0" encoding="UTF-8"?>
<includes>
    <include name="Animation_BounceIn_Dialog">
        <animation effect="fade" start="0" end="100" time="250">WindowOpen</animation>
        <animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
        <animation effect="fade" start="0" end="100" time="250">Visible</animation>
        <animation effect="fade" start="100" end="0" time="200">Hidden</animation>
    </include>

    <include name="Animation_FadeIn">
        <animation effect="fade" start="0" end="100" time="200">Visible</animation>
        <animation effect="fade" start="0" end="100" time="200">WindowOpen</animation>
    </include>

    <include name="Animation_FadeOut">
        <animation effect="fade" start="100" end="0" time="200">Hidden</animation>
        <animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
    </include>

    <include name="DefSettingsButton">
        <height>14</height>
    </include>

    <include name="Size_Dialog_Pad">
        <left>40</left>
        <right>40</right>
        <top>40</top>
        <bottom>40</bottom>
    </include>

    <include name="Size_Group_Head">
        <height>90</height>
    </include>

    <include name="Part_Line">
        <control type="image">
            <height>1</height>
            <texture colordiffuse="dialog_fg_70">common/white.png</texture>
            <centerbottom>0</centerbottom>
            <left>40</left>
            <right>40</right>
        </control>
    </include>

    <include name="Part_ChartButton">
        <control type="group">
            <width>1</width>
            <height>1</height>
        </control>
    </include>

    <include name="Part_HeadText">
        <param name="id">1</param>
        <param name="textcolor">dialog_fg_90</param>
        <param name="visible">true</param>
        <param name="left">40</param>
        <param name="top">28</param>
        <param name="right">40</param>
        <definition>
            <control type="label" id="$PARAM[id]">
                <label>$PARAM[label]</label>
                <font>Bold30</font>
                <textcolor>$PARAM[textcolor]</textcolor>
                <left>$PARAM[left]</left>
                <right>$PARAM[right]</right>
                <top>$PARAM[top]</top>
                <height>40</height>
                <visible>$PARAM[visible]</visible>
            </control>
        </definition>
    </include>

    <include name="Part_Background_Panel">
        <control type="image">
            <texture border="10">diffuse/panel.png</texture>
            <colordiffuse>$INFO[Skin.String(GeneralPanelsColor)]</colordiffuse>
            <animation effect="fade" end="85" time="0" condition="true">Conditional</animation>
        </control>
    </include>
</includes>
