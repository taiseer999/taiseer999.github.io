<?xml version="1.0" encoding="utf-8"?>
<!-- BINGIE -->
<includes>
	<!-- MyList -->
    <include name="bingie_items_mylist">
		<left>131</left>
        <include content="Custom_Container_Empty_Label">
            <param name="label" value="$VAR[MyListLabel]" />
        </include>
        <include content="ListHubContainerTemplate">
            <param name="widgetid" value="1510"/>
            <param name="contentPath" value="$VAR[Path_MyList]"/>
        </include>
    </include>
	
    <!-- Bingie Items PVR Hub -->
    <include name="bingie_items_pvr">
        <!-- Widget 1 -->
        <include content="widget_header_multi">
            <param name="widgetid" value="1510" />
            <param name="widgetName" value="Recently Watched" />
        </include>
        <include content="widget_base_normal">
            <param name="widgetid" value="1510" />
            <param name="widgetName" value="Recently Watched" />
            <param name="containerType" value="fixedlist" />
            <param name="contentStyle" value="normal" />
            <param name="widgetStyle" value="widget_layout_square" />
            <param name="visibility" value="true" />
            <param name="widgetTarget" value="" />
            <param name="widgetPath" value="pvr://channels/tv/*?view=lastplayed" />
            <param name="widgetSortBy" value="lastplayed" />
            <param name="widgetSortOrder" value="descending" />
            <param name="widgetLimit" value="$INFO[Skin.String(WidgetsGlobalLimit)]" />
        </include>
        <!-- Widget 2 -->
        <include content="widget_header_multi">
            <param name="widgetid" value="1520" />
            <param name="widgetName" value="Channels" />
        </include>
        <include content="widget_base_normal">
            <param name="widgetid" value="1520" />
            <param name="widgetName" value="Channels" />
            <param name="containerType" value="fixedlist" />
            <param name="contentStyle" value="normal" />
            <param name="widgetStyle" value="widget_layout_square" />
            <param name="visibility" value="true" />
            <param name="widgetTarget" value="" />
            <param name="widgetPath" value="pvr://channels/tv/*" />
            <param name="widgetSortBy" value="" />
            <param name="widgetSortOrder" value="" />
            <param name="widgetLimit" value="" />
        </include>
        <!-- Widget 3 -->
        <include content="widget_header_multi">
            <param name="widgetid" value="1530" />
            <param name="widgetName" value="Recordings" />
        </include>
        <include content="widget_base_normal">
            <param name="widgetid" value="1530" />
            <param name="widgetName" value="Recordings" />
            <param name="containerType" value="fixedlist" />
            <param name="contentStyle" value="normal" />
            <param name="widgetStyle" value="widget_layout_square" />
            <param name="visibility" value="true" />
            <param name="widgetTarget" value="" />
            <param name="widgetPath" value="pvr://recordings/tv/active?view=flat" />
            <param name="widgetSortBy" value="date" />
            <param name="widgetSortOrder" value="descending" />
            <param name="widgetLimit" value="" />
        </include>
        <!-- Widget 4 -->
        <include content="widget_header_multi">
            <param name="widgetid" value="1540" />
            <param name="widgetName" value="Live &amp; Radio" />
        </include>
        <include content="widget_base_normal">
            <param name="widgetid" value="1540" />
            <param name="widgetName" value="Live &amp; Radio" />
            <param name="containerType" value="fixedlist" />
            <param name="contentStyle" value="pvr" />
            <param name="widgetStyle" value="widget_layout_landscape" />
            <param name="visibility" value="true" />
            <param name="widgetTarget" value="" />
            <param name="widgetPath" value="" />
            <param name="widgetSortBy" value="" />
            <param name="widgetSortOrder" value="" />
            <param name="widgetLimit" value="" />
        </include>
    </include>

    <include name="Custom_Container_Empty_Label">
        <param name="id" default="1501" />
        <definition>
            <control type="button" id="$PARAM[id]">
                <visible>Integer.IsEqual(Container(1510).NumItems,0) + !Container(1510).IsUpdating</visible>
                <align>left</align>
				<left>-6</left>
                <include content="textoffsetx">
                    <param name="textoffsetx" value="25" />
                </include>
                <textoffsetx>0</textoffsetx>
                <texturenofocus/>
                <texturefocus/>
                <height>80</height>
                <width>99%</width>
                <font>Bold31</font>
                <textcolor>$INFO[Skin.String(ViewDetailsTextColor)]</textcolor>
                <focusedcolor>$INFO[Skin.String(ViewDetailsTextColor)]</focusedcolor>
                <label>$PARAM[label]</label>
            </control>
        </definition>
    </include>

    <include name="ListHubContainerTemplate">
        <control type="panel" id="$PARAM[widgetid]">			
            <viewtype label="31018">panel</viewtype>
            <width>1674</width>
            <height>474</height>			
            <itemgap>0</itemgap>
			<posy>42</posy>
            <orientation>vertical</orientation>
            <include>ScrollTime</include>
            <preloaditems>5</preloaditems>
            <onfocus condition="!String.IsEmpty(Window(Home).Property(KeepPlayingPreview))">ClearProperty(KeepPlayingPreview,Home)</onfocus>
            <onunfocus condition="System.HasAlarm(preview_delay)">CancelAlarm(preview_delay,silent)</onunfocus>
            <onunfocus condition="Skin.HasSetting(BingieAutoTrailer) + $EXP[IsPlayingUnrecognizedContent] + String.IsEmpty(Window(Home).Property(KeepPlayingPreview))">PlayerControl(Stop)</onunfocus>
            <include content="ContainerShowInfoOnclick" condition="Skin.HasSetting(ShowInformationBypass)">
                <param name="widgetid" value="$PARAM[widgetid]" />
            </include>
            <onright>noop</onright>
            <itemlayout height="339" width="239" condition="String.IsEqual(Skin.String(widgetstyle),poster)">
                <control type="group">
                    <width>240</width>
                    <height>340</height>
                    <include>PosterPanelBingieLayout</include>
                    <include>PosterTagOverlayBingieNoOverride</include>
                </control>
            </itemlayout>
            <focusedlayout height="339" width="239" condition="String.IsEqual(Skin.String(widgetstyle),poster)">
                <control type="group">
                    <width>240</width>
                    <height>340</height>
                    <include>PosterPanelBingieLayoutFocus</include>
                    <include>PosterTagOverlayBingieNoOverride</include>
                </control>
                <include content="HiddenWidgetButton">
					<param name="widgetstyle" value="poster"/>
					<param name="widgetid" value="$PARAM[widgetid]"/>
				</include>
            </focusedlayout>
			<itemlayout height="339" width="418" condition="String.IsEqual(Skin.String(widgetstyle),landscape)">
                    <control type="group">
                        <width>419</width>
                        <height>242</height>
                        <include>ThumbsViewBingieLayout</include>
						<control type="image">
							<!-- fallback logo image -->
							<height>242</height>
							<bottom>-68</bottom>
							<left>0</left>
							<bordersize>82</bordersize>
							<texture background="true">$VAR[ClearLogoFallback]</texture>
							<aspectratio scalediffuse="false" align="center" aligny="center">keep</aspectratio>
							<visible>String.IsEmpty(Listitem.Art(landscape)) + String.IsEmpty(ListItem.Property(landscape)) + !String.IsEqual(ListItem.DBTYPE,episode) + !String.IsEqual(ListItem.Property(DBTYPE),episode) + !Container.Content(episodes) + !String.IsEqual(ListItem.DBTYPE,season) + !String.IsEqual(ListItem.Property(DBTYPE),season)</visible>
							<visible>String.IsEmpty(ListItem.Property(defaultID))</visible>
						</control>
							<control type="label">
								<!--Label-->
								<left>7</left>
								<right>7</right>
								<bottom>-47</bottom>
								<height>61</height>
								<include condition="Skin.HasSetting(ThumbsLabelAlignmentCenter)">align_center</include>
								<align>left</align>
								<aligny>center</aligny>
								<label>[B]$VAR[ThumbListDetails_2][/B]</label>
								<font>Reg26</font>
								<autoscroll>false</autoscroll>
								<textcolor>$INFO[Skin.String(TagOverlaysTextColor)]</textcolor>
							</control>
							<control type="label">
								<!--Label-->
								<left>7</left>
								<right>7</right>
								<bottom>-80</bottom>
								<height>61</height>
								<include condition="Skin.HasSetting(ThumbsLabelAlignmentCenter)">align_center</include>
								<align>left</align>
								<aligny>center</aligny>
								<label>$VAR[ThumbListDetails_3]</label>
								<font>Reg26</font>
								<autoscroll>false</autoscroll>
								<textcolor>$INFO[Skin.String(TagOverlaysTextColor)]</textcolor>
							</control>
                    </control>
                </itemlayout>
                <focusedlayout height="339" width="418" condition="String.IsEqual(Skin.String(widgetstyle),landscape)">
                    <control type="group">
                        <width>419</width>
                        <height>242</height>
                        <include>ThumbsViewBingieLayoutFocus</include>
							<control type="image">
							<!-- fallback logo image -->
							<height>242</height>
							<bottom>-68</bottom>
							<left>0</left>
							<bordersize>82</bordersize>
							<texture background="true">$VAR[ClearLogoFallback]</texture>
							<aspectratio scalediffuse="false" align="center" aligny="center">keep</aspectratio>
							<visible>String.IsEmpty(Listitem.Art(landscape)) + String.IsEmpty(ListItem.Property(landscape)) + !String.IsEqual(ListItem.DBTYPE,episode) + !String.IsEqual(ListItem.Property(DBTYPE),episode) + !Container.Content(episodes) + !String.IsEqual(ListItem.DBTYPE,season) + !String.IsEqual(ListItem.Property(DBTYPE),season)</visible>
							<visible>String.IsEmpty(ListItem.Property(defaultID))</visible>
						</control>
						<control type="label">
							<!--Label-->
							<left>8</left>
							<right>8</right>
							<bottom>-47</bottom>
							<height>61</height>
							<include condition="Skin.HasSetting(ThumbsLabelAlignmentCenter)">align_center</include>
							<align>left</align>
							<aligny>center</aligny>
							<label>[B]$VAR[ThumbListDetails_2][/B]</label>
							<font>Reg26</font>
							<autoscroll>false</autoscroll>
							<textcolor>$INFO[Skin.String(TagOverlaysTextColor)]</textcolor>
						</control>
						<control type="label">
							<!--Label-->
							<left>8</left>
							<right>8</right>
							<bottom>-80</bottom>
							<height>61</height>
							<include condition="Skin.HasSetting(ThumbsLabelAlignmentCenter)">align_center</include>
							<align>left</align>
							<aligny>center</aligny>
							<label>$VAR[ThumbListDetails_3]</label>
							<font>Reg26</font>
							<autoscroll>false</autoscroll>
							<textcolor>$INFO[Skin.String(TagOverlaysTextColor)]</textcolor>
						</control>
                    </control>
                    <include content="HiddenWidgetButton">
						<param name="widgetstyle" value="landscape"/>
						<param name="widgetid" value="$PARAM[widgetid]"/>
					</include>
                </focusedlayout>
			<itemlayout height="339" width="279" condition="String.IsEqual(Skin.String(widgetstyle),square)">
                <control type="group">
                    <width>280</width>
                    <height>280</height>
                    <include>SquarePosterPanelBingieLayout</include>
					<control type="label">
						<!--Label-->
						<left>8</left>
						<right>8</right>
						<bottom>-47</bottom>
						<height>61</height>
						<include condition="Skin.HasSetting(ThumbsLabelAlignmentCenter)">align_center</include>
						<align>left</align>
						<aligny>center</aligny>
						<label>[B]$VAR[SquareListDetails][/B]</label>
						<font>Reg26</font>
						<textcolor>$INFO[Skin.String(TagOverlaysTextColor)]</textcolor>
					</control>
                </control>
            </itemlayout>
            <focusedlayout height="339" width="279" condition="String.IsEqual(Skin.String(widgetstyle),square)">
                <control type="group">
                    <width>280</width>
                    <height>280</height>
                    <include>SquarePosterPanelBingieLayoutFocus</include>
					<control type="label">
						<!--Label-->
						<left>8</left>
						<right>8</right>
						<bottom>-47</bottom>
						<height>61</height>
						<include condition="Skin.HasSetting(ThumbsLabelAlignmentCenter)">align_center</include>
						<align>left</align>
						<aligny>center</aligny>
						<label>[B]$VAR[SquareListDetails][/B]</label>
						<font>Reg26</font>
						<scroll>true</scroll>
						<textcolor>$INFO[Skin.String(TagOverlaysTextColor)]</textcolor>
					</control>
                </control>
                <include content="HiddenWidgetButton">
					<param name="widgetstyle" value="square"/>
					<param name="widgetid" value="$PARAM[widgetid]"/>
				</include>
            </focusedlayout>				
            <content target="videos">$PARAM[contentPath]</content>
        </control>
    </include>	
</includes>
