<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1114">
	<defaultcontrol always="true">9000</defaultcontrol>
	<include>Animation_DialogPopupOpenClose</include>
	<controls>
		<control type="group">
			<centerleft>50%</centerleft>
			<width>600</width>
			<centertop>50%</centertop>
			<height>350</height>
			<include content="DialogBackgroundCommons">
				<param name="width" value="600" />
				<param name="height" value="350" />
				<param name="header_label" value="Premiumize" />
				<param name="header_id" value="" />
				<param name="diffusetexture" value="masks/dialog-bg-squareish.png" />
			</include>
			<control type="panel" id="9000">
				<include>ButtonMenuList_dialog</include>
				<onback>Dialog.Close(1114)</onback>
				<onback>ActivateWindow(1111)</onback>
				<content>
					<item>
						<label>Fen Light</label>
						<visible>System.HasAddon(plugin.video.fenlight)</visible>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>RunPlugin(plugin://plugin.video.fenlight/?mode=premiumize.authenticate)</onclick>
					</item>
					<item>
						<label>Red Light</label>
						<visible>System.HasAddon(plugin.video.redlight)</visible>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>RunPlugin(plugin://plugin.video.redlight/?mode=premiumize.authenticate)</onclick>
					</item>
					<item>
						<label>The Gears</label>
						<visible>System.HasAddon(plugin.video.gears)</visible>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>RunPlugin(plugin://plugin.video.gears/?mode=premiumize.authenticate)</onclick>
					</item>
					<item>
						<label>Umbrella</label>
						<visible>System.HasAddon(plugin.video.umbrella)</visible>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>RunPlugin(plugin://plugin.video.umbrella/?action=pm_Authorize)</onclick>
					</item>
					<item>
						<label>POV</label>
						<visible>System.HasAddon(plugin.video.pov)</visible>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>PlayMedia("plugin://plugin.video.pov/?mode=myservices&amp;name=My+Services&amp;isFolder=false")</onclick>
					</item>
					<item>
						<label>ResolveURL Settings</label>
						<visible>System.HasAddon(script.module.resolverurl)</visible>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>RunScript(script.fentastic.helper,rurl_settings_pm)</onclick>
					</item>
				</content>
			</control>
			<include content="UpDownArrows">
				<param name="container_id" value="9000" />
				<param name="posx" value="276" />
				<param name="up_posy" value="-35" />
				<param name="down_posy" value="360" />
			</include>
		</control>
	</controls>
</window>
