<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1150">
    <defaultcontrol>100</defaultcontrol>
    <include>Animation_DialogPopupOpenClose</include>
    <depth>DepthDialog+</depth>
    <controls>
        <control type="group">
            <height>500</height>
            <centertop>50%</centertop>
            <centerleft>50%</centerleft>
            <width>915</width>
            <include content="DialogBackgroundCommons">
                <param name="width" value="915" />
                <param name="height" value="550" />
                <param name="header_label" value="Choose Look &amp; Feel" />
                <param name="header_id" value="1" />
                <param name="diffusetexture" value="masks/landscape-502.png" />
            </include>
            <control type="textbox" id="9">
                <left>30</left>
                <top>100</top>
                <width>855</width>
                <height>350</height>
                <label>Choose your preferred FENtastic experience:[CR][CR]1. Classic FENtastic[CR]2. FENtastic Plus[CR][CR]Don't worry — you can change this anytime in Skin Settings → Options → Look & Feel.</label>
                <autoscroll time="3000" delay="4000" repeat="5000">true</autoscroll>
            </control>

	    <!-- Classic FENtastic -->
            <control type="button" id="100">
                <left>135</left>
                <top>410</top>
                <width>300</width>
                <height>100</height>
                <label>Classic FENtastic</label>
                <font>font25_title</font>
                <align>center</align>
                <onright>101</onright>
                <onleft>101</onleft>
                <onclick>Skin.SetString(custombackground,special://skin/extras/backgrounds/redblur.jpg)</onclick>
		<onclick>Skin.Reset(customlogo)</onclick>
		<onclick>Skin.Reset(noiconmainmenu)</onclick>
		<onclick>Skin.SetBool(noiconmainmenu)</onclick>
		<onclick>Skin.SetBool(NoHighlightMainMenu)</onclick>
		<onclick>Skin.SetBool(noiconsilhouettes)</onclick>
		<onclick>Skin.SetBool(no_slide_animations)</onclick>
		<onclick>Skin.SetString(CurrentSkinColor,Classic FENtastic)</onclick>
                <onclick>RunScript(script.fentastic.helper,mode=set_fen_dflts)</onclick>
                <onclick>Skin.SetBool(ClassicFENtastic)</onclick>
                <onclick>Close</onclick>
                <texturefocus border="40" colordiffuse="button_focus">buttons/dialogbutton-fo.png</texturefocus>
                <texturenofocus border="40" colordiffuse="button_focus2">buttons/dialogbutton-nofo.png</texturenofocus>
            </control>

	    <!-- FENtastic Plus -->
            <control type="button" id="101">
                <left>480</left>
                <top>410</top>
                <width>300</width>
                <height>100</height>
                <label>FENtastic Plus</label>
                <font>font25_title</font>
                <align>center</align>
                <onleft>100</onleft>
                <onright>100</onright>
                <onclick>Skin.SetString(custombackground,special://skin/extras/backgrounds/redblur.jpg)</onclick>
                <onclick>Skin.SetString(customlogo,special://skin/extras/logos/fentastic.png)</onclick>
		<onclick>Skin.Reset(NoHighlightMainMenu)</onclick>
		<onclick>Skin.Reset(no_slide_animations)</onclick>
		<onclick>Skin.SetBool(noiconsilhouettes)</onclick>
		<onclick>Skin.SetString(CurrentSkinColor,FENtastic Plus)</onclick>
                <onclick>RunScript(script.fentastic.helper,mode=set_fenplus_dflts)</onclick>
                <onclick>Skin.Reset(ClassicFENtastic)</onclick>
                <onclick>Close</onclick>
                <texturefocus border="40" colordiffuse="button_focus">buttons/dialogbutton-fo.png</texturefocus>
                <texturenofocus border="40" colordiffuse="button_focus2">buttons/dialogbutton-nofo.png</texturenofocus>
            </control>
        </control>
    </controls>
</window>