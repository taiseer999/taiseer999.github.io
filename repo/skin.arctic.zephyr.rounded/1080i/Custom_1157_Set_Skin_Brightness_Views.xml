<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1157">
    <defaultcontrol>11</defaultcontrol>

    <controls>
        <include>Background_Overlay</include>

        <control type="group">
            <include content="Def_Dialog_Background">
                <param name="height" value="882" />
                <param name="width" value="1722" />
            </include>

            <include content="Def_Dialog_Header">
                <param name="label" value="$LOCALIZE[464]" />
                <param name="icon" value="skinsettings" />
            </include>

            <control type="list" id="11">
                <include>Animation_Scrolltime_Views_List</include>

                <top>112</top>
                <left>16</left>
                <width>418</width>
                <height>700</height>

                <onup>11</onup>
                <ondown>11</ondown>

                <onleft>close</onleft>

                <usecontrolcoords>true</usecontrolcoords>
                <itemgap>0</itemgap>

                <itemlayout width="418" height="70">
                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>PanelWhite100</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>String.IsEmpty(ListItem.Property(ItemSelected))</visible>
                    </control>
                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>$VAR[Color_List_Item_Selected]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>!String.IsEmpty(ListItem.Property(ItemSelected))</visible>
                    </control>
                    <include content="Def_Button_Radio">
                        <param name="colordiffuse_off" value="Black70" />
                        <param name="colordiffuse_on" value="$VAR[Color_List_Item_Selected]" />
                        <param name="visible" value="!String.IsEmpty(ListItem.Property(ItemSelected))" />
                    </include>
                </itemlayout>
                <focusedlayout width="418" height="70">

                    <!-- ITEM FOCUS -->

                    <include content="Def_Layout_Item_Focus">
                        <param name="fade_condition" value="Control.HasFocus(5)" />
                    </include>

                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>Selected</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <include content="Def_Button_Radio">
                        <param name="colordiffuse_off" value="Selected" />
                        <param name="colordiffuse_on" value="Selected" />
                        <param name="visible" value="!String.IsEmpty(ListItem.Property(ItemSelected))" />
                    </include>
                </focusedlayout>

                <!-- LIGHT -->

                <content>
                    <include>Set_Background_Brightness_Flix_Dialog_Info</include>
                </content>
            </control>

            <!-- LINE VERTICAL -->

            <include content="Def_Dialog_Line_Vertical"><param name="right" value="1272" /></include>

            <!-- VIEW TYPE ON RIGHT -->

            <include content="Def_Dialog_View_Type">
                <param name="fadetime" value="0" />
                <param name="texture" value="special://skin/extras/brightnessviews/$VAR[Def_Image_Skin_Brightness_Views].jpg" />
            </include>

            <!-- NUM ITEMS -->

            <include>Def_Dialog_Select_label_Num_Item</include>
        </control>
    </controls>
</window>
