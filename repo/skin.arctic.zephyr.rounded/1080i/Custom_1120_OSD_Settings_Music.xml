<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1120">
    <defaultcontrol always="true">9000</defaultcontrol>

    <controls>
        <include>Background_Overlay</include>
        <include>Animation_Common_Settings</include>

        <control type="group">
            <include content="Animation_Common_Context_Menu_Slide_Left"><param name="left" value="-490" /></include>

            <top>20</top>
            <centerleft>255</centerleft>

            <include content="Def_Dialog_Menu_Box">
                <param name="height" value="1039" />
                <param name="colordiffuse_border" value="$VAR[Color_OSD_Dialog_Border]" />
                <param name="colordiffuse_shadow" value="$VAR[Color_OSD_Dialog_Shadow]" />
                <param name="visible" value="ControlGroup(9000).HasFocus() | Control.HasFocus(1799)" />
            </include>

            <include content="Def_Dialog_Header">
                <param name="label" value="14018" />
                <param name="icon" value="settings" />
            </include>

            <control type="grouplist" id="9000">
                <include>Animation_Scrolltime_Views_List</include>

                <top>112</top>
                <height>910</height>

                <onup>9000</onup>
                <ondown>9000</ondown>
                <onright>1799</onright>
                <onleft>Dialog.Close(1120)</onleft>

                <itemgap>0</itemgap>
                <pagecontrol>1799</pagecontrol>
                <orientation>vertical</orientation>
                <usecontrolcoords>true</usecontrolcoords>

        <!-- OSD -->

                <control type="button" id="811">
                    <include>Def_Dialog_Menu_Button_Title</include>
                    <label>OSD</label>
                </control>

                <!-- SHOW OSD ON START X SECONDE -->

                <control type="radiobutton" id="820">
                    <description>Filter</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31185]</label>
                    <selected>Skin.HasSetting(show.osd.music.always.at.startup)</selected>
                    <onclick>Skin.ToggleSetting(show.osd.music.always.at.startup)</onclick>
                </control>

                <!-- AUTO HIDE OSD AFTER X SECONDE -->

                <control type="button" id="830">
                    <description>Auto close</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31232]</label>
                    <label2>$VAR[Label_Setting_OSD_Timeout]</label2>
                    <onclick>SetProperty(includesetting,Value_OSD_Auto_Hide_Timeout,Home)</onclick>
                    <onclick>ActivateWindow(1248)</onclick>
                </control>

                <!-- SHOW PLOT ON PAUSE -->

                <control type="radiobutton" id="823">
                    <description>Filter</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31588]</label>
                    <selected>Skin.HasSetting(show.osd.music.plot.on.pause)</selected>
                    <onclick>Skin.ToggleSetting(show.osd.music.plot.on.pause)</onclick>
                </control>

                <!-- HIDE OSD TIPS -->

                <control type="radiobutton" id="103">
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31603]</label>
                    <selected>Skin.HasSetting(hide.osd.music.tips)</selected>
                    <onclick>Skin.ToggleSetting(hide.osd.music.tips)</onclick>
                </control>

        <!-- INFO -->

                <control type="button" id="812">
                    <include>Def_Dialog_Menu_Button_Title</include>
                    <label>$LOCALIZE[19033]</label>
                </control>

                <!-- ALWAYS SHOW / AUTO HIDE -->

                <control type="radiobutton" id="832">
                    <description>Handlung</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31592]</label>
                    <selected>Skin.HasSetting(auto.hide.OSD.music.info)</selected>
                    <onclick>Skin.ToggleSetting(auto.hide.OSD.music.info)</onclick>
                    <onclick condition="Skin.HasSetting(auto.hide.OSD.music.info) + !Player.ShowInfo">Action(Info)</onclick>
                    <onclick condition="!Skin.HasSetting(auto.hide.OSD.music.info) + Player.ShowInfo">Action(Info)</onclick>
                </control>

                <!-- SET TIMEOUT -->

                <control type="button" id="831">
                    <description>Auto close</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31232]</label>
                    <label2>$VAR[Label_Setting_OSD_Music_Info_Timeout]</label2>
                    <onclick>SetProperty(includesetting,Value_OSD_Music_Info_Auto_Hide_Timeout,Home)</onclick>
                    <onclick>ActivateWindow(1248)</onclick>
                    <visible>Skin.HasSetting(auto.hide.OSD.music.info)</visible>
                </control>

        <!-- MEDIA INFO  -->

                <control type="button" id="1081">
                    <include>Def_Dialog_Menu_Button_Title</include>
                    <label>$LOCALIZE[20060]</label>
                </control>

                <!-- SHOW MUSIC RATING -->

                <control type="radiobutton" id="1080">
                    <description>Handlung</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[563]</label>
                    <selected>Skin.HasSetting(show.osd.music.rating)</selected>
                    <onclick>Skin.ToggleSetting(show.osd.music.rating)</onclick>
                </control>

                <!-- SHOW MUSIC NUMERIC RATING -->

                <control type="radiobutton" id="108">
                    <description>Handlung</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31408]</label>
                    <selected>Skin.HasSetting(musicosd.numericrating)</selected>
                    <onclick>Skin.ToggleSetting(musicosd.numericrating)</onclick>
                    <enable>Skin.HasSetting(show.osd.music.rating)</enable>
                </control>

        <!-- OTHERS -->

                <control type="button" id="804">
                    <include>Def_Dialog_Menu_Button_Title</include>
                    <label>$LOCALIZE[31052]</label>
                </control>

                <!-- SHOW CLEARLOGO -->

                <control type="radiobutton" id="120">
                    <description>Filter</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31248]</label>
                    <selected>Skin.HasSetting(show.osd.music.clearlogo)</selected>
                    <onclick>Skin.ToggleSetting(show.osd.music.clearlogo)</onclick>
                </control>

                <!-- SHOW SCROLLING TEXT -->

                <control type="radiobutton" id="107" description="Match theme">
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31407]</label>
                    <selected>!Skin.HasSetting(hide.music.visualisation.scrolling.text)</selected>
                    <onclick>Skin.ToggleSetting(hide.music.visualisation.scrolling.text)</onclick>
                </control>

        <!-- DISCART -->

                <control type="button" id="802">
                    <include>Def_Dialog_Menu_Button_Title</include>
                    <label>$LOCALIZE[31345]</label>
                </control>

                <!-- SELECT DISCART FALLBACK -->

                <control type="button" id="115">
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31293]:</label>
                    <label2>$VAR[Label_Setting_OSD_Music_Disc]</label2>
                    <onclick condition="!Skin.HasSetting(osd.music.disc.fallback.vinyl) + !Skin.HasSetting(osd.music.disc.fake.cd)">Skin.ToggleSetting(osd.music.disc.fallback.vinyl)</onclick>
                    <onclick condition="Skin.HasSetting(osd.music.disc.fallback.vinyl)">Skin.ToggleSetting(osd.music.disc.fake.cd)</onclick>
                    <onclick condition="Skin.HasSetting(osd.music.disc.fake.cd)">Skin.Reset(osd.music.disc.fake.cd)</onclick>
                    <onclick condition="Skin.HasSetting(osd.music.disc.fallback.vinyl)">Skin.Reset(osd.music.disc.fallback.vinyl)</onclick>
                </control>

                <!-- FALLBACK DISCART ONLY -->

                <control type="radiobutton" id="116">
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31497]</label>
                    <selected>Skin.HasSetting(osd.music.disc.fallback.only)</selected>
                    <onclick>Skin.ToggleSetting(osd.music.disc.fallback.only)</onclick>
                </control>

        <!-- BACKGROUND -->

                <control type="button" id="803">
                    <include>Def_Dialog_Menu_Button_Title</include>
                    <label>$LOCALIZE[33068]</label>
                </control>

                <!-- SHOW FANART -->

                <control type="radiobutton" id="130" description="Show Fanart">
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[20445]</label>
                    <selected>Skin.HasSetting(enable.osd.music.visualisation.fanart)</selected>
                    <onclick>Skin.ToggleSetting(enable.osd.music.visualisation.fanart)</onclick>
                    <onclick condition="!Skin.HasSetting(enable.osd.music.visualisation.fanart)">Skin.SetBool(disable.artist.slideshow)</onclick>
                    <onclick condition="Skin.HasSetting(enable.osd.music.visualisation.fanart) + !Skin.HasSetting(disable.artist.slideshow)">Skin.SetBool(disable.artist.slideshow)</onclick>
                </control>

                <!-- SHOW ARTIST SLIDESHOW -->

                <control type="radiobutton" id="131" description="Show slideshow in background">
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31409]</label>
                    <enable>System.AddonIsEnabled(script.artistslideshow)</enable>
                    <selected>!Skin.HasSetting(disable.artist.slideshow)</selected>
                    <onclick>Skin.ToggleSetting(disable.artist.slideshow)</onclick>
                    <onclick condition="Skin.HasSetting(disable.artist.slideshow)">Skin.SetBool(enable.osd.music.visualisation.fanart)</onclick>
                </control>

                <!-- ANIMATE SLIDESHOW -->

                <control type="radiobutton" id="132" description="Animate Artist slideshow">
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31265]</label>
                    <selected>Skin.HasSetting(enable.artist.slideshow.animate)</selected>
                    <onclick>Skin.ToggleSetting(enable.artist.slideshow.animate)</onclick>
                </control>

                <!-- FANART FALLBACK -->

                <control type="button" id="123" description="Fallback Fanart">
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31412]:</label>
                    <label2>$VAR[Label_OSD_Music_Fallback_Image]</label2>
                    <onclick>Skin.SetImage(fanart.fallback.music)</onclick>
                </control>

        <!-- VISUALISATION -->

                <control type="button" id="805">
                    <include>Def_Dialog_Menu_Button_Title</include>
                    <label>$LOCALIZE[24010]</label>
                </control>

                <!-- SELECT VISUALISATION ADDON -->

                <control type="button" id="140">
                    <description>Visualisation</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[250]:</label>
                    <label2 fallback="424">$VAR[Label_OSD_Music_Visualisation]</label2>
                    <onclick>Dialog.Close(all)</onclick>
                    <onclick>SendClick(500)</onclick>
                </control>

                <!-- VISUALISATION PRESET -->

                <control type="button" id="142">
                    <description>Visualisation</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[13388]:</label>
                    <label2>$VAR[Label_Setting_OSD_Music_Visualisation_Present]</label2>
                    <onclick>ActivateWindow(visualisationpresetlist)</onclick>
                    <enable>Visualisation.HasPresets</enable>
                </control>

                <!-- VISUALISATION SETTINGS -->

                <control type="button" id="141">
                    <description>Visualisation</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[5]</label>
                    <onclick>Addon.Default.OpenSettings(xbmc.player.musicviz)</onclick>
                    <enable>!String.IsEmpty(Visualisation.Name)</enable>
                </control>

                <!-- SHOW BEHIND FANART -->

                <control type="radiobutton" id="135" description="Show visualisation in background">
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31420]</label>
                    <selected>Skin.HasSetting(OSDVisualisation.ShowFanart)</selected>
                    <onclick>Skin.ToggleSetting(OSDVisualisation.ShowFanart)</onclick>
                    <enable>!String.IsEmpty(Visualisation.Name) + [Skin.HasSetting(enable.osd.music.visualisation.fanart) | [!Skin.HasSetting(disable.artist.slideshow) + System.AddonIsEnabled(script.artistslideshow)]]</enable>
                </control>

        <!-- LYRIC -->

                <control type="button" id="801">
                    <include>Def_Dialog_Menu_Button_Title</include>
                    <label>$LOCALIZE[24013]</label>
                </control>

                <!-- SHOW LYRIC -->

                <control type="radiobutton" id="81">
                    <description>Filter</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31012]</label>
                    <selected>Skin.HasSetting(musicosd.showvideolyrics)</selected>
                    <onclick>Skin.ToggleSetting(musicosd.showvideolyrics)</onclick>
                    <disabledcolor>$VAR[Color_OSD_Panel_White12]</disabledcolor>
                </control>

                <!-- LESS CONTRAST -->

                <control type="radiobutton" id="85">
                    <description>Filter</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[13379]</label>
                    <selected>!Skin.HasSetting(disable.osd.more.contrast)</selected>
                    <onclick>Skin.ToggleSetting(disable.osd.more.contrast)</onclick>
                    <disabledcolor>$VAR[Color_OSD_Panel_White12]</disabledcolor>
                </control>

                <!-- HIDE SEEKBAR -->

                <control type="radiobutton" id="92">
                    <description>Filter</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31405]</label>
                    <selected>Skin.HasSetting(hideseekbaronlyrics)</selected>
                    <onclick>Skin.ToggleSetting(hideseekbaronlyrics)</onclick>
                </control>

                <!-- HIDE OSD -->

                <control type="radiobutton" id="93">
                    <description>Filter</description>
                    <include>Def_Dialog_Menu_Button_Focus_Select</include>
                    <label>$LOCALIZE[31406]</label>
                    <selected>Skin.HasSetting(HideMusicOSDOnLyrics)</selected>
                    <onclick>Skin.ToggleSetting(HideMusicOSDOnLyrics)</onclick>
                </control>
            </control>

            <!-- SCROLLBAR -->

            <include content="Object_Scrollbar_Dialog_Vertical">
                <param name="scrollid" value="1799" />
                <param name="onleft" value="9000" />
                <param name="onright" value="Dialog.Close(1120)" />
                <param name="height" value="910" />
                <param name="centerright" value="4" />
            </include>
        </control>
    </controls>
</window>
