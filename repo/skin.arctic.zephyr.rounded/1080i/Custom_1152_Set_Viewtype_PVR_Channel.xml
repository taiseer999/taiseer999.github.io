<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1152">
    <defaultcontrol>11</defaultcontrol>

    <controls>
        <include>Background_Overlay</include>

        <control type="group">
            <include content="Def_Dialog_Background">
                <param name="height" value="882" />
                <param name="width" value="1722" />
            </include>

            <include content="Def_Dialog_Header">
                <param name="label" value="$LOCALIZE[582]: $LOCALIZE[19023]" />
                <param name="icon" value="skinsettings" />
            </include>

            <control type="list" id="11">
                <include>Animation_Scrolltime_Views_List</include>

                <top>112</top>
                <left>16</left>
                <width>418</width>
                <height>700</height>

                <onup>11</onup>
                <ondown>11</ondown>

                <usecontrolcoords>true</usecontrolcoords>
                <itemgap>0</itemgap>

                <itemlayout width="418" height="70">
                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>Black70</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>String.IsEmpty(ListItem.Property(ItemSelected))</visible>
                    </control>
                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>$VAR[Color_List_Item_Selected]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>!String.IsEmpty(ListItem.Property(ItemSelected))</visible>
                    </control>
                    <include content="Def_Button_Radio">
                        <param name="colordiffuse_off" value="Black70" />
                        <param name="colordiffuse_on" value="$VAR[Color_List_Item_Selected]" />
                        <param name="visible" value="!String.IsEmpty(ListItem.Property(ItemSelected))" />
                    </include>
                </itemlayout>
                <focusedlayout width="418" height="70">

                    <!-- ITEM FOCUS -->

                    <include content="Def_Layout_Item_Focus">
                        <param name="fade_condition" value="!Control.HasFocus(11)" />
                    </include>

                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>Selected</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <include content="Def_Button_Radio">
                        <param name="colordiffuse_off" value="Selected" />
                        <param name="colordiffuse_on" value="Selected" />
                        <param name="visible" value="!String.IsEmpty(ListItem.Property(ItemSelected))" />
                    </include>
                </focusedlayout>

                <!-- VERTICAL MULTI WIDGETS FLIX -->

                <content>
                    <item id="1">
                        <label>$LOCALIZE[535]</label>
                        <onclick>Skin.SetString(settingpvrviewmode,1)</onclick>
                        <onclick>Container.SetViewMode(50)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settingpvrviewmode),1)">Def_Item_Selected</include>

                    </item>
                    <item id="2">
                        <label>$LOCALIZE[31316]</label>
                        <onclick>Skin.SetString(settingpvrviewmode,2)</onclick>
                        <onclick>Container.SetViewMode(55)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settingpvrviewmode),2)">Def_Item_Selected</include>
                    </item>
                    <item id="3">
                        <visible>Window.IsVisible(MyPVRChannels.xml)</visible>
                        <label>$LOCALIZE[31217]</label>
                        <onclick>Skin.SetString(settingpvrviewmode,3)</onclick>
                        <onclick>Container.SetViewMode(54)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settingpvrviewmode),3)">Def_Item_Selected</include>
                    </item>
                    <item id="4">
                        <visible>Window.IsVisible(MyPVRChannels.xml)</visible>
                        <label>$LOCALIZE[31147]</label>
                        <onclick>Skin.SetString(settingpvrviewmode,4)</onclick>
                        <onclick>Container.SetViewMode(51)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settingpvrviewmode),4)">Def_Item_Selected</include>
                    </item>
                    <item id="5">
                        <visible>Window.IsVisible(MyPVRChannels.xml)</visible>
                        <label>$LOCALIZE[536]</label>
                        <onclick>Skin.SetString(settingpvrviewmode,5)</onclick>
                        <onclick>Container.SetViewMode(52)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settingpvrviewmode),5)">Def_Item_Selected</include>
                    </item>
                    <item id="6">
                        <visible>Window.IsVisible(MyPVRChannels.xml)</visible>
                        <label>$LOCALIZE[31556]</label>
                        <onclick>Skin.SetString(settingpvrviewmode,6)</onclick>
                        <onclick>Skin.SetString(settingthemecolor,3)</onclick>
                        <onclick>Container.SetViewMode(526)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settingpvrviewmode),6)">Def_Item_Selected</include>
                    </item>
                </content>
            </control>

            <!-- LINE VERTICAL -->

            <include content="Def_Dialog_Line_Vertical"><param name="right" value="1272" /></include>

            <!-- VIEW TYPE ON RIGHT -->

            <include content="Def_Dialog_View_Type">
                <param name="texture" value="special://skin/extras/viewtypes_pvr/$VAR[Def_Image_PVR_Channel_View_Type].jpg" />
            </include>

            <!-- NUM ITEMS -->

            <include>Def_Dialog_Select_label_Num_Item</include>

        </control>
    </controls>
</window>
