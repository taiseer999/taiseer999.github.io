<?xml version="1.0" encoding="UTF-8"?>
<window>
    <defaultcontrol always="true">52</defaultcontrol>
    <onload>SetProperty(SkinInitStarted,1,Home)</onload>
    <controls>
        <control type="group">
            <visible>!Player.HasVideo</visible>
            <visible>!String.IsEmpty(Window(Home).Property(SkinInitStarted))</visible>

            <!-- FANART STARTUP -->

            <include>Background_Startup</include>

            <!-- BACKGROUND LOGIN -->

            <control type="group">
                <animation effect="fade" start="100" end="0" time="500">WindowClose</animation>

                <width>960</width>
                <height>690</height>
                <bottom>186</bottom>
                <centerleft>50%</centerleft>


                <control type="image">
                    <texture border="80" colordiffuse="B3333333">diffuse/circlebutton_160_flat.png</texture>
                    <animation effect="fade" start="100" end="90" condition="true">Conditional</animation>
                </control>
            </control>

            <control type="group">
                <animation effect="fade" start="100" end="0" time="500">WindowClose</animation>

                <width>880</width>
                <height>670</height>
                <bottom>166</bottom>
                <centerleft>50%</centerleft>

                <include content="Def_Dialog_Header">
                    <param name="label" value="$LOCALIZE[20115]" />
                    <param name="label_color" value="CCC5C5C5" />
                    <param name="icon" value="kodi" />
                    <param name="icon_color" value="CCC5C5C5" />
                    <param name="line_color" value="1FBBBBBB" />
                </include>
            </control>

            <control type="button" id="20">
                <description>Close</description>
                <centerleft>50%</centerleft>
                <bottom>260</bottom>
                <width>320</width>

                <font>Button</font>
                <textcolor>B3BBBBBB</textcolor>
                <height>68</height>
                <onfocus>ClearProperty(content)</onfocus>

                <texturenofocus border="12" colordiffuse="1FBBBBBB">common/box12.png</texturenofocus>
                <texturefocus border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</texturefocus>
                <alttexturefocus border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</alttexturefocus>
                <alttexturenofocus border="12" colordiffuse="1FBBBBBB">common/box12.png</alttexturenofocus>

                <onleft>52</onleft>
                <onright>52</onright>
                <onup>52</onup>
                <ondown>52</ondown>

                <label>10111</label>
                <onclick>ActivateWindow(ShutdownMenu)</onclick>
            </control>

            <control type="list" id="52">
                <visible>!Window.IsVisible(ProfileSettings.xml)</visible>

                <top>360</top>
                <left>635</left>
                <width>650</width>
                <height>360</height>

                <onleft>20</onleft>
                <onright>20</onright>
                <onup>20</onup>
                <ondown>20</ondown>

                <scrolltime tween="cubic" easing="out">500</scrolltime>
                <movement>1</movement>

                <itemlayout height="120">
                    <control type="label">
                        <left>140</left>
                        <top>20</top>
                        <width>490</width>
                        <height>40</height>
                        <textcolor>4DC5C5C5</textcolor>
                        <font>InfoNetflix</font>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <control type="label">
                        <left>140</left>
                        <top>59</top>
                        <width>490</width>
                        <height>40</height>
                        <textcolor>4DC5C5C5</textcolor>
                        <label>$INFO[ListItem.Label2]</label>
                        <font>Tiny</font>
                    </control>
                </itemlayout>
                <focusedlayout height="120">
                    <control type="image">
                        <visible>String.StartsWith(ListItem.Icon,Default)</visible>
                        <left>13</left>
                        <centertop>50%</centertop>
                        <width>100</width>
                        <height>100</height>
                        <aspectratio scalediffuse="false">scale</aspectratio>
                        <texture colordiffuse="FFC5C5C5" diffuse="login_screen/circle_full.png" fallback="DefaultActor.png">$INFO[Listitem.Icon]</texture>
                        <animation effect="slide" start="0,120" end="0,0" time="300" reversible="false" tween="back" easing="out" condition="Container(52).OnPrevious">Focus</animation>
                        <animation effect="slide" start="0,-120" end="0,0" time="300" reversible="false" tween="back" easing="out" condition="Container(52).OnNext">Focus</animation>
                        <animation effect="fade" start="100" end="50" time="300" tween="sine" easing="inout" condition="!Control.HasFocus(52)">Conditional</animation>
                    </control>
                    <control type="image">
                        <visible>!String.StartsWith(ListItem.Icon,Default)</visible>
                        <left>13</left>
                        <centertop>50%</centertop>
                        <width>100</width>
                        <height>100</height>
                        <aspectratio scalediffuse="false">scale</aspectratio>
                        <texture diffuse="login_screen/circle_full.png" fallback="DefaultActor.png">$INFO[Listitem.Icon]</texture>
                        <animation effect="slide" start="0,120" end="0,0" time="300" reversible="false" tween="back" easing="out" condition="Container(52).OnPrevious">Focus</animation>
                        <animation effect="slide" start="0,-120" end="0,0" time="300" reversible="false" tween="back" easing="out" condition="Container(52).OnNext">Focus</animation>
                        <animation effect="fade" start="100" end="50" time="300" tween="sine" easing="inout" condition="!Control.HasFocus(52)">Conditional</animation>
                    </control>
                    <control type="image">
                        <left>13</left>
                        <centertop>50%</centertop>
                        <width>100</width>
                        <height>100</height>
                        <texture colordiffuse="Selected">login_screen/circle.png</texture>
                        <animation effect="slide" start="0,120" end="0,0" time="300" reversible="false" tween="back" easing="out" condition="Container(52).OnPrevious">Focus</animation>
                        <animation effect="slide" start="0,-120" end="0,0" time="300" reversible="false" tween="back" easing="out" condition="Container(52).OnNext">Focus</animation>
                        <animation effect="fade" start="100" end="50" time="300" tween="sine" easing="inout" condition="!Control.HasFocus(52)">Conditional</animation>
                    </control>
                    <control type="group">
                        <animation type="Focus" condition="Container(52).OnNext | Container(52).OnPrevious" reversible="false">
                            <effect type="fade" start="50" end="100" time="300" tween="sine" easing="inout" />
                        </animation>
                        <animation effect="fade" start="100" end="50" time="300" tween="sine" easing="inout" condition="!Control.HasFocus(52)">Conditional</animation>
                        <control type="label">
                            <left>140</left>
                            <top>20</top>
                            <width>490</width>
                            <height>40</height>
                            <font>InfoNetflix</font>
                            <textcolor>Selected</textcolor>
                            <label>$INFO[ListItem.Label]</label>
                        </control>
                        <control type="label">
                            <left>140</left>
                            <top>59</top>
                            <width>490</width>
                            <height>40</height>
                            <textcolor>FFC5C5C5</textcolor>
                            <label>$INFO[ListItem.Label2]</label>
                            <font>Tiny</font>
                        </control>
                    </control>
                </focusedlayout>
            </control>
        </control>
    </controls>
</window>
