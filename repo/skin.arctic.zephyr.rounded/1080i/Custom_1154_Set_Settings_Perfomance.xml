<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1154">
    <defaultcontrol always="true">11</defaultcontrol>

    <onload>ClearProperty(reloadsetupwizard,Home)</onload>
    <onload>ClearProperty(SetupWizardDirection,Home)</onload>

    <onunload condition="!String.IsEmpty(Window(Home).Property(reloadskin))">SetFocus(3033)</onunload>
    <onunload condition="!String.IsEmpty(Window(Home).Property(reloadsetupwizard))">SetFocus(3099)</onunload>
    <onunload condition="String.IsEmpty(Window(Home).Property(reloadsetupwizard)) + String.IsEmpty(Window(Home).Property(SetupWizardDirection)) + Window.IsVisible(Custom_1100_Startup.xml) + !Window.IsVisible(1153) + !Window.IsVisible(1154) + !Window.IsVisible(1155) + !Window.IsVisible(1156)">AlarmClock(DelayFocus3615,SetFocus(3615),00:00,silent)</onunload>

    <controls>
        <include>Background_Overlay</include>

        <control type="group">
            <include content="Def_Dialog_Background">
                <param name="height" value="882" />
                <param name="width" value="1722" />
            </include>

            <include content="Def_Dialog_Header">
                <param name="label" value="$LOCALIZE[166] - $LOCALIZE[5] / $LOCALIZE[31364]" />
                <param name="icon" value="skinsettings" />
            </include>

            <control type="list" id="11">
                <include>Animation_Scrolltime_Views_List</include>

                <top>112</top>
                <left>16</left>
                <width>418</width>
                <height>210</height>

                <onup>11</onup>
                <ondown>11</ondown>

                <onleft condition="!$EXP[Condition_Show_Button_Setup_Wizard]">close</onleft>
                <onleft condition="$EXP[Condition_Show_Button_Setup_Wizard]">9010</onleft>

                <onright condition="!$EXP[Condition_Show_Button_Setup_Wizard]">11</onright>
                <onright condition="$EXP[Condition_Show_Button_Setup_Wizard]">9020</onright>

                <usecontrolcoords>true</usecontrolcoords>
                <itemgap>0</itemgap>

                <itemlayout width="418" height="70">
                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>Black70</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>String.IsEmpty(ListItem.Property(ItemSelected))</visible>
                    </control>
                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>$VAR[Color_List_Item_Selected]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>!String.IsEmpty(ListItem.Property(ItemSelected))</visible>
                    </control>
                    <include content="Def_Button_Radio">
                        <param name="colordiffuse_off" value="Black70" />
                        <param name="colordiffuse_on" value="$VAR[Color_List_Item_Selected]" />
                        <param name="visible" value="!String.IsEmpty(ListItem.Property(ItemSelected))" />
                    </include>
                </itemlayout>
                <focusedlayout width="418" height="70">

                    <!-- ITEM FOCUS -->

                    <include content="Def_Layout_Item_Focus">
                        <param name="fade_condition" value="!Control.HasFocus(11)" />
                    </include>

                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>Selected</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <include content="Def_Button_Radio">
                        <param name="colordiffuse_off" value="Selected" />
                        <param name="colordiffuse_on" value="Selected" />
                        <param name="visible" value="!String.IsEmpty(ListItem.Property(ItemSelected))" />
                    </include>
                </focusedlayout>

                <!-- PERFORMANCE -->

                <content>
                    <item id="1">
                        <label>$LOCALIZE[31610]</label>

                        <include>Def_Disable_All_TMDb_Helper_Services</include>
                        <include>Def_Performance_Value</include>
                        <include>Def_Settings_Clearlogo_Disable_All</include>

                        <onclick>Skin.SetString(settingperflevel,1)</onclick>
                        <onclick condition="!$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(reloadskin,1,Home)</onclick>

                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(reloadsetupwizard,1154,Home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(SetupWizardDirection,Next,Home)</onclick>
                        <onclick>Close</onclick>

                        <include condition="String.IsEqual(Skin.String(settingperflevel),1)">Def_Item_Selected</include>
                    </item>

                    <!-- BALANCED - DEFAULT -->

                    <item id="2">
                        <label>$LOCALIZE[31611] ($LOCALIZE[571])</label>

                        <include>Def_Enable_All_TMDb_Helper_Services</include>
                        <include>Def_Settings_Clearlogo_Disable_All</include>
                        <include>Def_Settings_All_Default_Value</include>

                        <onclick>Skin.SetString(settingperflevel,2)</onclick>
                        <onclick condition="!$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(reloadskin,1,Home)</onclick>

                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(reloadsetupwizard,1154,Home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(SetupWizardDirection,Next,Home)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settingperflevel),2)">Def_Item_Selected</include>
                    </item>

                    <!-- QUALITY -->

                    <item id="3">
                        <label>$LOCALIZE[31612]</label>

                        <include>Def_Enable_All_TMDb_Helper_Services</include>
                        <include>Def_Settings_All_Default_Value</include>
                        <include>Def_Settings_Clearlogo_Enable_All</include>
                        <include>Def_Settings_Quality_Value</include>

                        <onclick>Skin.SetString(settingperflevel,3)</onclick>
                        <onclick condition="!$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(reloadskin,1,Home)</onclick>

                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(reloadsetupwizard,1154,Home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(SetupWizardDirection,Next,Home)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settingperflevel),3)">Def_Item_Selected</include>
                    </item>
                </content>
            </control>

            <!-- LINE VERTICAL -->

            <include content="Def_Dialog_Line_Vertical"><param name="right" value="1272" /></include>

            <!-- VIEW TYPE ON RIGHT -->

            <include content="Def_Dialog_View_Type">
                <param name="texture" value="special://skin/extras/performance/$VAR[Def_Image_Settings_Performance].jpg" />
            </include>

            <!-- TIPS - FOOTER -->

            <include content="Object_Footer_Tips">
                <param name="top" value="818" />
                <param name="left" value="478" />
                <param name="label" value="31599" />
                <param name="textcolor" value="Black70" />
                <param name="visible" value="Container(11).HasFocus(1)" />
            </include>

            <!-- BUTTON OK / PREV / NEXT -->

            <include condition="$EXP[Condition_Show_Button_Setup_Wizard]">Def_Button_Setup_Wizard</include>

            <!-- NUM ITEMS -->

            <include>Def_Dialog_Select_label_Num_Item</include>
        </control>
    </controls>
</window>
