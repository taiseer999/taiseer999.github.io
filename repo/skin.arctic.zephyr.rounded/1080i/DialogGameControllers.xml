<?xml version="1.0" encoding="UTF-8"?>
<window>
	<description>
		Window for game functionality. This dialog was originally for controllers,
		but adding new XML windows breaks old skins, so it has been repurposed
		for any game-related windows.
	</description>

    <defaultcontrol always="true">3</defaultcontrol>

    <controls>
        <include content="Background_Overlay">
            <param name="visible" value="!Window.IsVisible(GameOSD.xml)" />
        </include>

        <include condition="Window.IsDialogTopMost(gamecontrollers)">Def_Dialog_Game_Controllers</include>
        <include condition="Window.IsDialogTopMost(gameports)">Def_Dialog_Game_Ports</include>
        <include condition="Window.IsDialogTopMost(gameagents)">Def_Dialog_Game_Agents</include>
        <include condition="Window.IsDialogTopMost(gamediscmanager)">Def_Dialog_Game_DiscManager</include>
    </controls>
</window>
