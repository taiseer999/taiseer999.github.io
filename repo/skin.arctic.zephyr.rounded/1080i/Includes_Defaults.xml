<?xml version="1.0" encoding="UTF-8"?>
<includes>
    <default type="label">
        <height>66</height>
        <aligny>center</aligny>
        <font>Small</font>
        <textcolor>Black70</textcolor>
        <focusedcolor>Black70</focusedcolor>
        <selectedcolor>$VAR[Color_List_Item_Selected]</selectedcolor>
        <disabledcolor>Black30</disabledcolor>
    </default>

    <default type="edit">
        <height>66</height>
        <align>center</align>
        <aligny>center</aligny>
        <font>Small</font>
        <textoffsetx>30</textoffsetx>
        <textcolor>Black70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <selectedcolor>$VAR[Color_List_Item_Selected]</selectedcolor>
        <disabledcolor>White12</disabledcolor>
        <texturefocus colordiffuse="White30">common/white.png</texturefocus>
        <texturenofocus />
        <pulseonselect>false</pulseonselect>
    </default>

    <default type="fadelabel">
        <height>66</height>
        <align>left</align>
        <aligny>center</aligny>
        <font>Small</font>
        <textcolor>White70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <selectedcolor>$VAR[Color_List_Item_Selected]</selectedcolor>
        <disabledcolor>White12</disabledcolor>
        <scrollout>false</scrollout>
        <pauseatend>2000</pauseatend>
    </default>

    <default type="image">
    </default>

    <default type="button">
        <height>66</height>
        <align>center</align>
        <aligny>center</aligny>
        <font>Small</font>
        <textoffsetx>30</textoffsetx>
        <textcolor>Black70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <disabledcolor>Black30</disabledcolor>
        <selectedcolor>$VAR[Color_List_Item_Selected]</selectedcolor>
        <texturefocus colordiffuse="White12">common/white.png</texturefocus>
        <texturenofocus />
        <pulseonselect>false</pulseonselect>
    </default>

    <default type="colorbutton">
        <height>66</height>
        <align>center</align>
        <aligny>center</aligny>
        <font>Small</font>
        <textoffsetx>30</textoffsetx>
        <textcolor>Black70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <disabledcolor>Black30</disabledcolor>
        <colorwidth>88</colorwidth>
        <colorheight>28</colorheight>
        <texturecolormask>buttons/colorbox.png</texturecolormask>
        <texturecolordisabledmask colordiffuse="40FFFFFF">buttons/colorbox.png</texturecolordisabledmask>
        <texturefocus colordiffuse="White12">common/white.png</texturefocus>
        <texturenofocus />
        <pulseonselect>false</pulseonselect>
    </default>

    <default type="togglebutton">
        <height>66</height>
        <align>center</align>
        <aligny>center</aligny>
        <font>Small</font>
        <textoffsetx>30</textoffsetx>
        <textcolor>Black70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <selectedcolor>$VAR[Color_List_Item_Selected]</selectedcolor>
        <disabledcolor>Black30</disabledcolor>
        <texturefocus colordiffuse="White12">common/white.png</texturefocus>
        <texturenofocus />
        <alttexturefocus colordiffuse="White12">common/white.png</alttexturefocus>
        <alttexturenofocus />
        <pulseonselect>false</pulseonselect>
    </default>

    <default type="radiobutton">
        <height>66</height>
        <align>center</align>
        <aligny>center</aligny>
        <font>Small</font>
        <radioposx>1257</radioposx>
        <radioposy>22</radioposy>
        <radiowidth>26</radiowidth>
        <radioheight>26</radioheight>
        <textoffsetx>30</textoffsetx>
        <textcolor>Black70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <disabledcolor>Black30</disabledcolor>
        <selectedcolor>$VAR[Color_List_Item_Selected]</selectedcolor>
        <texturefocus colordiffuse="White12">common/white.png</texturefocus>
        <texturenofocus />

        <textureradiofocus colordiffuse="Black70">buttons/radio-on.png</textureradiofocus>
        <textureradionofocus colordiffuse="Black70">buttons/radio-off.png</textureradionofocus>
        <textureradioondisabled colordiffuse="Black12">buttons/radio-on.png</textureradioondisabled>
        <textureradiooffdisabled colordiffuse="Black12">buttons/radio-off.png</textureradiooffdisabled>

        <textureradioonfocus colordiffuse="Selected">buttons/radio-on.png</textureradioonfocus>
        <textureradioofffocus colordiffuse="Selected">buttons/radio-off.png</textureradioofffocus>
        <textureradioonnofocus colordiffuse="Black70">buttons/radio-on.png</textureradioonnofocus>
        <textureradiooffnofocus colordiffuse="Black70">buttons/radio-off.png</textureradiooffnofocus>

        <textoffsetx>30</textoffsetx>
        <pulseonselect>false</pulseonselect>
    </default>

    <default type="spincontrolex">
        <height>66</height>
        <font>Small</font>
        <spinwidth>32</spinwidth>
        <spinheight>32</spinheight>
        <textcolor>Black70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <disabledcolor>Black12</disabledcolor>
        <selectedcolor>$VAR[Color_List_Item_Selected]</selectedcolor>
        <texturefocus colordiffuse="White12">common/white.png</texturefocus>
        <texturenofocus />

        <textureup flipy="true" colordiffuse="Black70">buttons/spin-down.png</textureup>
        <texturedown colordiffuse="Black70">buttons/spin-down.png</texturedown>
        <textureupfocus flipy="true" colordiffuse="Selected">buttons/spin-down.png</textureupfocus>
        <texturedownfocus colordiffuse="Selected">buttons/spin-down.png</texturedownfocus>
        <textureupdisabled flipy="true" colordiffuse="Black12">buttons/spin-down.png</textureupdisabled>
        <texturedowndisabled colordiffuse="Black12">buttons/spin-down.png</texturedowndisabled>

        <textoffsetx>30</textoffsetx>
        <align>left</align>
        <aligny>center</aligny>
        <reverse>yes</reverse>
        <pulseonselect>false</pulseonselect>
    </default>

    <default type="spincontrol">
        <height>66</height>
        <font>Small</font>
        <spinwidth>32</spinwidth>
        <spinheight>32</spinheight>
        <textcolor>Black70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <disabledcolor>Black12</disabledcolor>
        <selectedcolor>$VAR[Color_List_Item_Selected]</selectedcolor>
        <texturefocus colordiffuse="White12">common/white.png</texturefocus>
        <texturenofocus />
        <textureup flipy="true" colordiffuse="Black70">buttons/spin-down.png</textureup>
        <texturedown colordiffuse="Black70">buttons/spin-down.png</texturedown>
        <textureupfocus flipy="true" colordiffuse="Selected">buttons/spin-down.png</textureupfocus>
        <texturedownfocus colordiffuse="Selected">buttons/spin-down.png</texturedownfocus>
        <textureupdisabled flipy="true" colordiffuse="Black12">buttons/spin-down.png</textureupdisabled>
        <texturedowndisabled colordiffuse="Black12">buttons/spin-down.png</texturedowndisabled>
        <textoffsetx>30</textoffsetx>
        <align>left</align>
        <aligny>center</aligny>
        <reverse>yes</reverse>
        <pulseonselect>false</pulseonselect>
    </default>

    <default type="progress">
        <texturebg colordiffuse="2f5f5f5f" border="8,0,8,0">progress/progress-nib.png</texturebg>
        <lefttexture />
        <midtexture colordiffuse="$VAR[Color_Focus]" border="8,0,8,0">progress/progress-nib.png</midtexture>
        <righttexture />
        <overlaytexture/>
    </default>

    <default type="slider">
        <width>360</width>
        <height>12</height>
        <orientation>horizontal</orientation>
        <texturefocus />
        <texturenofocus />
        <texturesliderbar colordiffuse="SliderBarColor" border="6">slider/slider_bg.png</texturesliderbar>
        <textureslidernib colordiffuse="SliderNibColor" border="6">slider/slider_nib.png</textureslidernib>
        <textureslidernibfocus colordiffuse="Selected" border="6">slider/slider_nib.png</textureslidernibfocus>
    </default>

    <default type="sliderex">
        <height>66</height>
        <orientation>horizontal</orientation>
        <selectedcolor>$VAR[Color_List_Item_Selected]</selectedcolor>
        <sliderwidth>192</sliderwidth>
        <sliderheight>12</sliderheight>
        <texturesliderbar colordiffuse="SliderBarColor" border="6">slider/slider_bg.png</texturesliderbar>
        <textureslidernib colordiffuse="SliderNibColor" border="6">slider/slider_nib.png</textureslidernib>
        <textureslidernibfocus colordiffuse="Selected" border="6">slider/slider_nib.png</textureslidernibfocus>
        <font>Small</font>
        <aligny>center</aligny>
        <textcolor>Black70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <disabledcolor>Black12</disabledcolor>
        <textoffsetx>30</textoffsetx>
        <textoffsety>0</textoffsety>
        <pulseonselect>false</pulseonselect>
    </default>

    <default type="scrollbar">
        <width>8</width>
        <texturesliderbackground colordiffuse="White12">common/white.png</texturesliderbackground>
        <texturesliderbar colordiffuse="White30">common/white.png</texturesliderbar>
        <texturesliderbarfocus colordiffuse="$VAR[Color_OSD_Slider_Nib_Focus]">common/white.png</texturesliderbarfocus>
        <textureslidernib />
        <textureslidernibfocus />
        <showonepage>false</showonepage>
        <orientation>vertical</orientation>
    </default>

    <default type="textbox">
        <font>Small</font>
        <textcolor>Black70</textcolor>
        <shadowcolor />
        <selectedcolor>$VAR[Color_List_Item_Selected]</selectedcolor>

        <!-- COMMENT FOR NO BUG WITH "SCROLLBAR" IN SCRIPT-WIKIPEDIA.XML  -->
        <!--                <pagecontrol>61</pagecontrol>                 -->

        <autoscroll delay="10000" time="4000" repeat="10000">Skin.HasSetting(widgets.autoscrollingplot)</autoscroll>
    </default>
</includes>
