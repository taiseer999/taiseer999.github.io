<?xml version="1.0" encoding="UTF-8"?>
<window>
    <defaultcontrol always="true">901</defaultcontrol>
    <allowoverlay>no</allowoverlay>

    <visible>!Player.HasGame</visible>
    <visible>!Window.IsActive(DialogPlayerProcessInfo.xml)</visible>

    <visible>Window.IsActive(MusicVisualisation.xml) | !String.IsEmpty(Window(Home).Property(OSDVideo_Show_AT_START_INFO)) | [VideoPlayer.IsFullscreen + [Window.IsVisible(videoosd) | Window.IsVisible(fullscreeninfo) | Player.Seeking | Player.HasPerformedSeek(3) | Player.Paused | !String.IsEmpty(Player.SeekNumeric) | !String.IsEmpty(PVR.ChannelNumberInput) | Player.Forwarding | Player.Rewinding | !String.IsEmpty(Window(Home).Property(OSDVideo_Show_INFO)) | [Player.ShowInfo + VideoPlayer.Content(livetv)]]]</visible>

    <visible>!Window.IsVisible(DialogSlider.xml) + !Window.IsVisible(DialogSelect.xml) + !Window.IsVisible(DialogSettings.xml) + !Window.IsVisible(DialogSubtitles.xml)</visible>

    <visible>!Window.IsVisible(DialogPVRChannelsOSD.xml) + !Window.IsVisible(DialogPVRChannelGuide.xml)</visible>

    <visible>!Window.IsVisible(script-wikipedia.xml)</visible>

    <onload condition="[!String.IsEmpty(Window(Home).Property(OSDVideo_DIALOG_VIDEO_INFO)) | !String.IsEmpty(Window(Home).Property(wikipedia))] + Skin.HasSetting(osd.open.auto.pause) + Player.Paused + VideoPlayer.IsFullscreen + !Window.IsVisible(DialogFullScreenInfo.xml) + !String.IsEmpty(VideoPlayer.DBID) + !Integer.IsEqual(Window(Home).Property(wikipedia),1)">PlayerControl(Play)</onload>

    <onload condition="[!String.IsEmpty(Window(Home).Property(OSDVideo_DIALOG_VIDEO_INFO)) | !String.IsEmpty(Window(Home).Property(wikipedia))] + Skin.HasSetting(osd.open.auto.pause) + Player.Paused + VideoPlayer.IsFullscreen + !Window.IsVisible(DialogFullScreenInfo.xml) + !String.IsEmpty(VideoPlayer.DBID)">AlarmClock(cleanup,ClearProperty(OSDVideo_DIALOG_VIDEO_INFO,Home),00:01,silent)</onload>

    <onload condition="Skin.HasSetting(show.osd.video.plot.on.pause) + Skin.HasSetting(show.osd.info.on.pause) + !String.IsEmpty(Window(Home).Property(OSDVideo_DIALOG_FULL_SCREEN_INFO)) + Player.Paused + !Window.IsVisible(videoosd) + !Window.IsVisible(DialogFullScreenInfo.xml)">ClearProperty(OSDVideo_DIALOG_FULL_SCREEN_INFO,Home)</onload>

    <onunload>ClearProperty(OSDVideo_Show_INFO,Home)</onunload>
    <onunload>ClearProperty(OSDVideo_Show_PLOT,Home)</onunload>
    <onunload>ClearProperty(OSDVideo_Show_LiveTV_PLOT,Home)</onunload>
    <onunload>ClearProperty(OSDVideo_Slider_Is_Focus,Home)</onunload>

    <zorder>0</zorder>

    <controls>

        <!-- BACKGROUND ON DISPLAY PLOT -->

        <include condition="VideoPlayer.IsFullscreen">Object_OSD_Video_Plot_Background</include>

        <!-- SEEKBAR VIDEO -->

        <include condition="VideoPlayer.IsFullscreen">OSD_Video_SeekBar</include>

        <!-- SEEKBAR MUSIC -->

        <include condition="!VideoPlayer.IsFullscreen">OSD_Music_SeekBar</include>

        <!-- CHANNEL LOGO -->

        <include>Def_OSD_Channel_Logo</include>

        <!-- CHANNEL NUMBER PVR -->

        <include>Def_OSD_Channel_Number_Input</include>

        <!-- CLOCK -->

        <include>Object_OSD_Video_Clock</include>
    </controls>
</window>
