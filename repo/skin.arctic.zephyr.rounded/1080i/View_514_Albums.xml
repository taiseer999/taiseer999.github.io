<?xml version="1.0" encoding="UTF-8"?>
<includes>

    <include name="514Content">
        <visible>$EXP[Exp_View_514]</visible>
        <include>Animation_Scrolltime_Views_List</include>

        <top>306</top>
        <left>View_Poster_Side</left>
        <width>View_Poster_Width</width>
        <height>330</height>

        <onup condition="!Skin.HasSetting(global.kioskmode)">9000</onup>
        <onup condition="!Skin.HasSetting(global.kioskmode) + [Player.HasMedia | Player.Playing]">AlarmClock(GoToButtonFullScreen,SetFocus(6157),00:00,silent)</onup>
        <ondown>1616</ondown>
        <onleft>514</onleft>
        <onright>514</onright>

        <preloaditems>2</preloaditems>
        <pagecontrol>1616</pagecontrol>
        <orientation>horizontal</orientation>
        <focusposition>1</focusposition>

        <viewtype label="31177">list</viewtype>

        <itemlayout height="330" width="299.66">
            <control type="group">
                <top>5</top>
                <height>280</height>
                <width>280</width>
                <include content="Layout_Widget_Square">
                    <param name="texture_diffuse" value="square_w260_h260" />
                    <param name="id" value="514" />
                    <param name="height" value="280" />
                    <param name="image_height" value="280" />
                    <param name="top" value="260" />
                    <param name="distance" value="10" />
                </include>
            </control>
        </itemlayout>
        <focusedlayout height="330" width="299.66">
            <control type="group">
                <top>5</top>
                <height>280</height>
                <width>280</width>
                <include content="Layout_Widget_Square_Focus">
                    <param name="texture_diffuse" value="square_w260_h260" />
                    <param name="id" value="514" />
                    <param name="height" value="280" />
                    <param name="image_height" value="280" />
                    <param name="top" value="260" />
                    <param name="distance" value="10" />
                    <param name="glow_height" value="276" />
                </include>
            </control>
        </focusedlayout>
    </include>

    <include name="514Wrap">
        <control type="panel" id="514">
            <include>514Content</include>
        </control>
    </include>

    <include name="514Fixed">
        <control type="fixedlist" id="514">
            <include>514Content</include>
        </control>
    </include>

    <include name="View_514_Albums">
        <description>List View (id=514)</description>
        <control type="group">
            <visible>Control.IsVisible(514)</visible>
            <include>Animation_Common_Global</include>

            <include condition="!Skin.HasSetting(show.clock.date.weather.home.only) + !Skin.HasSetting(show.furniture.footer)">Furniture_Footer_Clock_Right</include>

            <control type="group">

                <!-- CLEARLOGO -->

                <control type="image" description="clearlogo">
                    <animation effect="slide" start="0,0" end="-735,0" time="200" condition="Skin.HasSetting(514NoCenter)">Conditional</animation>
                    <visible>Skin.HasSetting(show.view.514.title.clearlogo) + $EXP[Title_Clearlogo_Available]</visible>
                    <top>180</top>
                    <height>ClearLogoTitleMaxHeight</height>
                    <width>ClearLogoTitleMaxWidth</width>
                    <centerleft>50%</centerleft>
                    <aspectratio align="center" aligny="top">keep</aspectratio>
                    <texture background="true">$VAR[Image_Crop_ClearLogo]</texture>
                    <fadetime>ClearArtFadetime</fadetime>
                </control>

                <!-- MAIN TILE  -->

                <control type="label">
                    <visible>!Skin.HasSetting(show.view.514.title.clearlogo) | [!$EXP[Title_Clearlogo_Available] + Skin.HasSetting(show.view.514.title.clearlogo)]</visible>
                    <top>220</top>
                    <include condition="!Skin.HasSetting(514NoCenter)">Def_Views_509_514_Center_Info</include>
                    <left>View_List_Side</left>
                    <description>Header Label</description>
                    <textcolor>Dark1</textcolor>
                    <font>LargeNew</font>
                    <label fallback="19055">$INFO[ListItem.Artist]</label>
                </control>

                <control type="grouplist">
                    <visible>!ListItem.IsParentFolder</visible>

                    <left>View_List_Side</left>
                    <top>620</top>
                    <height>600</height>

                    <itemgap>15</itemgap>
                    <orientation>vertical</orientation>

                    <control type="label">
                        <height>36</height>
                        <font>InfoNetflix</font>
                        <animation effect="slide" start="0,0" end="100,0" time="200" condition="!Skin.HasSetting(514NoCenter)">Conditional</animation>
                        <include condition="!Skin.HasSetting(514NoCenter)">Def_Views_509_514_Center_Info</include>
                        <textcolor>Dark1</textcolor>
                        <label fallback="19055">$VAR[LabelSub_1_GenreAlbum]</label>
                    </control>

                    <control type="textbox">
                        <visible>[!String.IsEmpty(ListItem.Property(Artist_Description)) + Container.Content(artists)] | [!String.IsEmpty(ListItem.Property(Album_Description)) + Container.Content(albums)] | Container.Content(movies) | Container.Content(tvshows) | Container.Content(sets) | Container.Content(videos) | Container.Content(episodes)</visible>
                        <left>View_List_Side</left>
                        <include condition="!Skin.HasSetting(514NoCenter)">Def_Views_509_514_Center_Info</include>
                        <animation effect="slide" start="0,0" end="100,0" time="200" condition="!Skin.HasSetting(514NoCenter)">Conditional</animation>
                        <font>Tiny</font>
                        <height min="36" max="108">auto</height>
                        <textcolor>Dark2</textcolor>
                        <selectedcolor>Dark2</selectedcolor>
                        <label>$VAR[Label_Plot_Box_Video_Music]</label>
                    </control>

                    <control type="label">
                        <height>36</height>
                        <font>InfoNetflix</font>
                        <animation effect="slide" start="0,0" end="100,0" time="200" condition="!Skin.HasSetting(514NoCenter)">Conditional</animation>
                        <include condition="!Skin.HasSetting(514NoCenter)">Def_Views_509_514_Center_Info</include>
                        <textcolor>Dark2</textcolor>
                        <label fallback="19055">$VAR[Label_View_Flix_Sub_Title]</label>
                        <visible>!Container.Content(artists) + !Container.Content(albums)</visible>
                    </control>
                </control>
            </control>

            <!-- SCROLLBAR -->

            <control type="scrollbar" id="1616">
                <include content="Object_Scrollbar_Views_Horizontal">
                    <param name="scrollid" value="1616" />
                    <param name="bottom" value="474" />
                </include>
            </control>

            <include condition="!Skin.HasSetting(514NoCenter)">514Wrap</include>
            <include condition="Skin.HasSetting(514NoCenter)">514Fixed</include>
        </control>

        <include content="Hidden_List_Artist_Album_Count" condition="!Skin.HasSetting(disable.all.hidden.list)"><param name="id" value="514" /></include>
    </include>

</includes>
