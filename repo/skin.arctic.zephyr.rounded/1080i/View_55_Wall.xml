                        <top>5</top>
                        <left>10</left>
                        <width>880</width>
                        <height>315</height>

                        <control type="group">
                            <visible>Control.HasFocus(55)</visible>

                            <animation type="Focus">
                                <effect type="zoom" start="10,0,202,315" end="10,0,874,315" tween="cubic" easing="inout" delay="1000" time="400" />
                                <effect type="fade" start="0" end="100" tween="cubic" easing="inout" delay="200" time="150" />
                            </animation>

                            <include content="Def_Art_Full_Background_b12">
                                <param name="colordiffuse" value="Panel" />
                            </include>
                        </control>

                        <include>Def_55_Info_Right</include>
                    </control>

                    <!-- SLIDE INFO ON FOCUS -->

                    <control type="group">
                        <visible>Skin.HasSetting(55wall.slideinfo) + !ListItem.IsParentFolder</visible>
                        <visible>Container(55).Column(4) | Container(55).Column(5) | Container(55).Column(6) | Container(55).Column(7)</visible>

