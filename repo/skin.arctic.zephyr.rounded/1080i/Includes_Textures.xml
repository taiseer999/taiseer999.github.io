<?xml version="1.0" encoding="UTF-8"?>
<includes>
    <include name="Texture_Shadow_20">
        <param name="colordiffuse" default="80000000" />
        <param name="texture_shadow" value="$PARAM[texture_shadow]" default="$VAR[shadow20]" />

        <definition>
            <include content="Def_Padding"><param name="pad" value="-20" /></include>
            <bordersize>20</bordersize>
            <bordertexture border="32" colordiffuse="$PARAM[colordiffuse]">$PARAM[texture_shadow]</bordertexture>
        </definition>
    </include>

    <include name="Texture_Highlight_Focus">
        <texturefocus border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</texturefocus>
        <alttexturefocus border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</alttexturefocus>
    </include>

    <include name="Texture_Image_Dialog_Settings">
        <texture border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</texture>
    </include>

    <include name="Texture_Dialog_ColorBox">
        <alttexturefocus  colordiffuse="$VAR[Color_Focus]">common/white.png</alttexturefocus>
        <texturefocus  colordiffuse="$VAR[Color_Focus]">common/white.png</texturefocus>
    </include>

    <include name="Texture_Layout_Item_Focus">
        <texture border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</texture>
    </include>

    <include name="Texture_PVR_Item_Focus">
        <texture colordiffuse="$VAR[Color_Focus]">common/white.png</texture>
    </include>

    <include name="Texture_SelectBox">
        <texture border="18" colordiffuse="$VAR[Color_Focus]">common/selectbox.png</texture>
    </include>

    <!-- BUTTON -->

    <include name="Texture_Button_Info">
        <texturenofocus border="12" colordiffuse="Dark4">common/box12.png</texturenofocus>
        <texturefocus border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</texturefocus>
        <alttexturefocus border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</alttexturefocus>
        <alttexturenofocus border="12" colordiffuse="Dark4">common/box12.png</alttexturenofocus>
    </include>

    <include name="Texture_RadioButton_Dialog_Info">
        <param name="color" value="$PARAM[color]" default="Dark4" />
        <param name="texture" value="$PARAM[texture]" default="common/box12.png" />
        <definition>
            <font>Null</font>
            <textcolor>Dark2</textcolor>
            <texturenofocus colordiffuse="$PARAM[color]" border="12">$PARAM[texture]</texturenofocus>
            <texturefocus border="12" colordiffuse="$VAR[Color_Focus]">$PARAM[texture]</texturefocus>
            <textureradioonfocus colordiffuse="FFFFFFFF">$PARAM[icon]</textureradioonfocus>
            <textureradioonnofocus colordiffuse="Dark2">$PARAM[icon]</textureradioonnofocus>
            <textureradioofffocus colordiffuse="FFFFFFFF">$PARAM[icon]</textureradioofffocus>
            <textureradiooffnofocus colordiffuse="Dark2">$PARAM[icon]</textureradiooffnofocus>
            <textureradiooffdisabled colordiffuse="1FFFFFFF">$PARAM[icon]</textureradiooffdisabled>
            <textureradioondisabled colordiffuse="1FFFFFFF">$PARAM[icon]</textureradioondisabled>
        </definition>
    </include>

    <include name="Texture_RadioButton_Dialog_Circle">
        <param name="color" value="$PARAM[color]" default="Dark4" />
        <param name="texture" value="$PARAM[texture]" default="common/circle80.png" />
        <definition>
            <font>Null</font>
            <textcolor>Dark2</textcolor>
            <texturenofocus colordiffuse="$PARAM[color]" >$PARAM[texture]</texturenofocus>
            <texturefocus colordiffuse="$VAR[Color_Focus]">$PARAM[texture]</texturefocus>
            <textureradioonfocus colordiffuse="FFFFFFFF">$PARAM[icon]</textureradioonfocus>
            <textureradioonnofocus colordiffuse="Dark2">$PARAM[icon]</textureradioonnofocus>
            <textureradioofffocus colordiffuse="FFFFFFFF">$PARAM[icon]</textureradioofffocus>
            <textureradiooffnofocus colordiffuse="Dark2">$PARAM[icon]</textureradiooffnofocus>
            <textureradiooffdisabled colordiffuse="1FFFFFFF">$PARAM[icon]</textureradiooffdisabled>
            <textureradioondisabled colordiffuse="1FFFFFFF">$PARAM[icon]</textureradioondisabled>
        </definition>
    </include>

    <include name="Texture_Button_Dialog_Info">
        <texturenofocus border="12" colordiffuse="Dark4">common/box12.png</texturenofocus>
        <texturefocus border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</texturefocus>
    </include>

    <include name="Texture_Button_Dialog_Settings">
        <param name="colordiffuse_nofocus" value="$PARAM[colordiffuse_nofocus]" default="$VAR[Color_Button_NoFocus]" />
        <definition>
            <texturenofocus border="12" colordiffuse="$PARAM[colordiffuse_nofocus]">common/box12.png</texturenofocus>
            <texturefocus border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</texturefocus>
        </definition>
    </include>

    <include name="Texture_Dialog_Settings">
        <texturefocus border="12" colordiffuse="$VAR[Color_Focus]">common/box12.png</texturefocus>
    </include>

    <!-- DIALOG -->

    <include name="Texture_Circle_80">
        <texture border="40" colordiffuse="$VAR[Color_Focus]">common/circle80.png</texture>
    </include>

    <include name="Texture_Dialog_Line">
        <texture colordiffuse="$VAR[Color_Dialog_Line]">common/white.png</texture>
    </include>

    <include name="Texture_Arrow_Up">
        <param name="colordiffuse" value="$PARAM[colordiffuse]" default="Dark2" />
        <definition>
             <texture colordiffuse="$PARAM[colordiffuse]" flipy="true">common/arrow_small_down.png</texture>
        </definition>
    </include>

    <include name="Texture_Arrow_Down">
        <param name="colordiffuse" value="$PARAM[colordiffuse]" default="Dark2" />
        <definition>
             <texture colordiffuse="$PARAM[colordiffuse]" flipy="false">common/arrow_small_down.png</texture>
        </definition>
    </include>

    <include name="Texture_Dialog_Search">
        <texture border="40" colordiffuse="$VAR[Color_Focus]">common/menu.png</texture>
    </include>

    <!-- KEYBOARD -->

    <include name="Texture_Dialog_Keyboard">
        <texturefocus border="9" colordiffuse="$VAR[Color_Focus]">common/box9.png</texturefocus>
    </include>

    <include name="Texture_Keyboard_Keys">
        <texturenofocus border="9" colordiffuse="Black12">common/box9.png</texturenofocus>
        <texturefocus border="9" colordiffuse="$VAR[Color_Focus]">common/box9.png</texturefocus>
    </include>

    <include name="Texture_History_Keyboard_Focus">
        <texture border="9" colordiffuse="$VAR[Color_Focus]">common/box9.png</texture>
    </include>

    <include name="Texture_Keyboard_Standard">
        <texture border="9" colordiffuse="Black12">common/box9.png</texture>
    </include>

    <include name="Texture_Dialog_NumPad">
        <font>Null</font>
        <textcolor>Dark2</textcolor>
        <texturenofocus colordiffuse="Black12" border="9">common/box9.png</texturenofocus>
        <texturefocus border="9" colordiffuse="$VAR[Color_Focus]">common/box9.png</texturefocus>
        <textureradioonfocus colordiffuse="FFFFFFFF">$PARAM[icon]</textureradioonfocus>
        <textureradioonnofocus colordiffuse="Black70">$PARAM[icon]</textureradioonnofocus>
        <textureradioofffocus colordiffuse="FFFFFFFF">$PARAM[icon]</textureradioofffocus>
        <textureradiooffnofocus colordiffuse="Black70">$PARAM[icon]</textureradiooffnofocus>
        <textureradiooffdisabled colordiffuse="disabled">$PARAM[icon]</textureradiooffdisabled>
        <textureradioondisabled colordiffuse="disabled">$PARAM[icon]</textureradioondisabled>
    </include>

    <!-- SCROLLBAR -->

    <include name="Texture_Scrollbar_H">
        <texturesliderbackground border="4" colordiffuse="Dark4">scrollbar/scrollh.png</texturesliderbackground>
        <texturesliderbar border="4" colordiffuse="Dark3">scrollbar/scrollh.png</texturesliderbar>
        <texturesliderbarfocus border="4" colordiffuse="$VAR[Color_Focus]">scrollbar/scrollh.png</texturesliderbarfocus>
    </include>

    <include name="Texture_Scrollbar_V">
        <texturesliderbackground border="4" colordiffuse="Dark4">scrollbar/scrollv.png</texturesliderbackground>
        <texturesliderbar border="4" colordiffuse="Dark3">scrollbar/scrollv.png</texturesliderbar>
        <texturesliderbarfocus border="4" colordiffuse="$VAR[Color_Focus]">scrollbar/scrollv.png</texturesliderbarfocus>
    </include>

    <!-- HOME - WIDGET -->

    <include name="Texture_Home_Menu_Underline">
        <texture border="4" colordiffuse="$VAR[Color_Focus]">common/underline_menu.png</texture>
    </include>

    <include name="Texture_Home_Menu_Button_Underline">
        <texturenofocus border="4" colordiffuse="$VAR[Color_Focus]">common/underline_button_menu.png</texturenofocus>
    </include>

    <include name="Texture_Home_Info_Flix_Underline">
        <texturenofocus colordiffuse="Dark3">common/underline_home_info_flix.png</texturenofocus>
    </include>

    <include name="Texture_Widget_Bullet">
        <texture colordiffuse="Dark2">common/circlebutton.png</texture>
    </include>

    <include name="Texture_Widget_Bullet_Focus">
        <texture colordiffuse="$VAR[Color_Focus]">common/circlebutton.png</texture>
    </include>

    <include name="Texture_Glow_32">
        <texture border="32" colordiffuse="$VAR[Color_Focus]">common/glow.png</texture>
    </include>

    <include name="Texture_Glow_40">
        <texture border="40" colordiffuse="$VAR[Color_Focus]">common/glow.png</texture>
    </include>

    <!-- OSD -->

    <include name="Texture_OSD_Button">
        <param name="back_colordiffuse" value="$PARAM[back_colordiffuse]" default="$VAR[Color_Background]" />
        <definition>
            <texturefocus flipy="true" colordiffuse="$VAR[Color_Focus]">common/circle80.png</texturefocus>
            <texturenofocus colordiffuse="$PARAM[back_colordiffuse]">common/circle80.png</texturenofocus>
        </definition>
    </include>

    <include name="Texture_OSD_Slider_Marker">
        <texture colordiffuse="$VAR[Color_OSD_Slider_Bar]">common/white.png</texture>
    </include>
</includes>
