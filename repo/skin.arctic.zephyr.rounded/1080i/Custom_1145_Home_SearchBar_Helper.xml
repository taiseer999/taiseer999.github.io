<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1145">
    <visible>$EXP[Has_Home_menu_Auto_Focus_Main_If_SearchBar_Inactivity]</visible>

    <!-- HOME - FOCUS CONTROLS NOW PLAYING IF VISIBLE -->

    <onload condition="$EXP[Has_Home_menu_Auto_Focus_Main_If_SearchBar_Inactivity] + [$EXP[Extended_Now_Playing_Is_Enable] + Window.IsVisible(Home) + Player.HasMedia]">SetFocus(777)</onload>

    <!-- HOME - FOCUS CONTROLS MAIN MENU -->

    <onload condition="$EXP[Has_Home_menu_Auto_Focus_Main_If_SearchBar_Inactivity] + ![$EXP[Extended_Now_Playing_Is_Enable] + Window.IsVisible(Home) + Player.HasMedia]">SetProperty(first_menu,1,Home)</onload>

    <onload condition="$EXP[Has_Home_menu_Auto_Focus_Main_If_SearchBar_Inactivity] + ![$EXP[Extended_Now_Playing_Is_Enable] + Window.IsVisible(Home) + Player.HasMedia]">SetFocus(300)</onload>

    <onload condition="$EXP[Has_Home_menu_Auto_Focus_Main_If_SearchBar_Inactivity] + ![$EXP[Extended_Now_Playing_Is_Enable] + Window.IsVisible(Home) + Player.HasMedia] + $EXP[Home_Is_Horizontal]">SetProperty(AnimationDirection,Right,Home)</onload>

    <onload condition="$EXP[Has_Home_menu_Auto_Focus_Main_If_SearchBar_Inactivity] + ![$EXP[Extended_Now_Playing_Is_Enable] + Window.IsVisible(Home) + Player.HasMedia] + $EXP[Home_Is_Vertical]">SetProperty(AnimationDirection,Down,Home)</onload>

    <onload condition="$EXP[Has_Home_menu_Auto_Focus_Main_If_SearchBar_Inactivity] + ![$EXP[Extended_Now_Playing_Is_Enable] + Window.IsVisible(Home) + Player.HasMedia]">$VAR[Set_TMDB_Helper_Widget_Container_left_up]</onload>

    <onload condition="$EXP[Has_Home_menu_Auto_Focus_Main_If_SearchBar_Inactivity]">ClearProperty(focus_main_menu_timer_from_search_bar,Home)</onload>
    <controls />
</window>
