    <!-- INFO -->

    <include name="57_List_Info">
        <param name="top" value="$PARAM[top]" default="576" />
        <param name="left" value="$PARAM[left]" default="View_List_Side" />
        <param name="width" value="$PARAM[width]" default="PosterH" />
        <param name="visible" value="$PARAM[visible]" default="true" />
        <param name="width_condition" value="$PARAM[width_condition]" default="Skin.HasSetting(show.furniture.progress.circle)" />
        <param name="animation_condition" value="$PARAM[animation_condition]" default="false" />
        <param name="visible_progress" value="$PARAM[visible_progress]" default="true" />
        <param name="infobox_height" value="$PARAM[infobox_height]" default="290" />
        <param name="plot_height" value="$PARAM[plot_height]" default="140" />

        <definition>
            <control type="group">
                <visible>$PARAM[visible]</visible>
                <visible>!$EXP[IsYoutube_Comments]</visible>

                <top>$PARAM[top]</top>
                <left>$PARAM[left]</left>
                <width>$PARAM[width]</width>
                <height>$PARAM[infobox_height]</height>

                <!-- MAIN TITLE -->

                <control type="group">
                    <include content="Def_Width" condition="$PARAM[width_condition]">
                        <param name="width" value="520" />
                    </include>
                    <width>100%</width>

                    <control type="label">
                        <top>8</top>
                        <aligny>center</aligny>
                        <height>64</height>
                        <font>SmallBold</font>
                        <textcolor>Dark1</textcolor>
                        <selectedcolor>Dark1</selectedcolor>
                        <label>$VAR[Label_Main_Title_Fanart_56_57]</label>
                    </control>
                </control>

                <!-- SUB TITLE -->

                <include content="Def_Label_View_Flix_Sub_Title">
                    <param name="top" value="48" />
                    <param name="width_condition" value="$PARAM[width_condition]" />
                </include>

                <!-- PLOT -->

                <include content="Def_Label_View_Flix_Plot">
                    <param name="visible" value="[!$EXP[IsAnPlugin] | $EXP[IsTMDbHelper] | $EXP[IsYoutubeItem] | $EXP[IsPluginShortlist] | $EXP[IsLibraryGenie] | $EXP[IsPluginJLOM] | $EXP[IsPluginApplePodcasts]]" />
                    <param name="top" value="124" />
                    <param name="align" value="justify" />
                    <param name="height" value="$PARAM[plot_height]" />
                </include>

                <!-- PROGRESS -->

                <include content="Def_View_Info_Circle_Progress" condition="Skin.HasSetting(show.furniture.progress.circle)">
                    <param name="top" value="-8" />
                </include>
            </control>
        </definition>
    </include>
