    <include name="Def_Game_Image_Background">
        <param name="pad_shadow" value="$PARAM[pad_shadow]" default="7" />
        <param name="border_shadow" value="$PARAM[border_shadow]" default="22" />
        <param name="texture_shadow" value="$PARAM[texture_shadow]" default="$VAR[shadow12]" />
        <param name="colordiffuse_shadow" value="$PARAM[colordiffuse_shadow]" default="$VAR[Color_Shadow]" />
        <param name="visible_shadow" value="$PARAM[visible_shadow]" default="true" />

        <param name="pad_border" value="$PARAM[pad_border]" default="7" />
        <param name="border_border" value="$PARAM[border_border]" default="20" />
        <param name="texture_border" value="$PARAM[texture_border]" default="$VAR[border12]" />
        <param name="colordiffuse_border" value="$PARAM[colordiffuse_border]" default="$VAR[Color_Border_Widget]" />
        <param name="visible_border" value="$PARAM[visible_border]" default="true" />


        <param name="pad_image" value="$PARAM[pad_image]" default="16" />
        <param name="colordiffuse" value="$PARAM[colordiffuse]" default="White100" />
        <param name="condition_fade" value="$PARAM[condition_fade]" default="false" />

        <param name="visible" value="$PARAM[visible]" default="true" />

        <definition>
            <control type="image">
                <include content="Def_Padding"><param name="pad" value="$PARAM[pad_shadow]" /></include>
                <texture border="$PARAM[border_shadow]" colordiffuse="$PARAM[colordiffuse_shadow]" infill="false">$PARAM[texture_shadow]</texture>
                <visible>!Skin.HasSetting(hide.global.shadows)</visible>
                <visible>$PARAM[visible_shadow]</visible>
                <visible>$PARAM[visible]</visible>
            </control>
            <control type="image">
                <include content="Def_Padding"><param name="pad" value="$PARAM[pad_border]" /></include>
                <texture border="$PARAM[border_border]" colordiffuse="$PARAM[colordiffuse_border]" infill="false">$PARAM[texture_border]</texture>
                <visible>Skin.HasSetting(hide.global.shadows)</visible>
                <visible>$PARAM[visible_border]</visible>
                <visible>$PARAM[visible]</visible>
            </control>
            <control type="image">
                <include content="Def_Padding"><param name="pad" value="$PARAM[pad_image]" /></include>
                <texture border="12" colordiffuse="black">$VAR[texture_box12]</texture>
                <animation effect="fade" start="100" end="90" condition="$PARAM[condition_fade]">Conditional</animation>
                <visible>!String.IsEqual(ListItem.Icon,DefaultAddSource.png)</visible>
                <visible>$PARAM[visible]</visible>
            </control>
            <control type="image">
                <include content="Def_Padding"><param name="pad" value="$PARAM[pad_image]" /></include>
                <texture border="12" colordiffuse="$PARAM[colordiffuse]">$VAR[texture_box12]</texture>
                <animation effect="fade" start="100" end="90" condition="$PARAM[condition_fade]">Conditional</animation>
                <visible>String.IsEqual(ListItem.Icon,DefaultAddSource.png)</visible>
                <visible>$PARAM[visible]</visible>
            </control>
        </definition>
    </include>

