            <!-- LINE VERTICAL -->

            <include content="Def_Dialog_Line_Vertical"><param name="right" value="1272" /></include>

            <!-- VIEW TYPE ON RIGHT -->

            <include content="Def_Dialog_View_Type">
                <param name="texture" value="special://skin/extras/homemenu/$VAR[Def_Image_Home_Menu_View_type].jpg" />
                <param name="visible" value="!Skin.HasSetting(home.show.menu.icons)" />
            </include>
            <include content="Def_Dialog_View_Type">
                <param name="texture" value="special://skin/extras/homemenu/$VAR[Def_Image_Home_Menu_View_type]2.jpg" />
                <param name="visible" value="Skin.HasSetting(home.show.menu.icons)" />
            </include>

            <!-- LINE HORIZONTALE -->

            <control type="image">
                <top>653</top>
                <left>30</left>
                <width>404</width>
                <height>1</height>
                <include>Texture_Dialog_Line</include>
            </control>

