                    <param name="width" value="388" />
                    <param name="align" value="left" />
                    <param name="label" value="$LOCALIZE[31562] :" />
                    <param name="label2" value="$VAR[Label_Setting_Home_Menu_Style]" />
                    <param name="selected" value="Skin.HasSetting(home.show.menu.icons)" />
