                <left>16</left>
                <width>418</width>
                <height>700</height>

                <onup>11</onup>
                <ondown>11</ondown>

                <onleft condition="!$EXP[Condition_Show_Button_Setup_Wizard]">close</onleft>
                <onleft condition="$EXP[Condition_Show_Button_Setup_Wizard]">5</onleft>

                <onright>5</onright>

                <usecontrolcoords>true</usecontrolcoords>
                <itemgap>0</itemgap>

                <itemlayout width="418" height="70">
                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>Black70</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>String.IsEmpty(ListItem.Property(ItemSelected))</visible>
                    </control>
                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>$VAR[Color_List_Item_Selected]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>!String.IsEmpty(ListItem.Property(ItemSelected))</visible>
                    </control>
                    <include content="Def_Button_Radio">
                        <param name="colordiffuse_off" value="Black70" />
                        <param name="colordiffuse_on" value="$VAR[Color_List_Item_Selected]" />
                        <param name="visible" value="!String.IsEmpty(ListItem.Property(ItemSelected))" />
                    </include>
                </itemlayout>
                <focusedlayout width="418" height="70">

                    <!-- ITEM FOCUS -->

                    <include content="Def_Layout_Item_Focus">
                        <param name="fade_condition" value="!Control.HasFocus(11)" />
                    </include>

                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>Selected</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <include content="Def_Button_Radio">
                        <param name="colordiffuse_off" value="Selected" />
                        <param name="colordiffuse_on" value="Selected" />
                        <param name="visible" value="!String.IsEmpty(ListItem.Property(ItemSelected))" />
                    </include>
                </focusedlayout>

                <!-- VERTICAL MULTI WIDGETS FLIX -->

                <content>
                    <item id="1">
                        <label>$LOCALIZE[31182] $LOCALIZE[31004]</label>
                        <include>Def_Reset_View_types</include>
                        <onclick>Skin.SetString(settinghomestyle,1)</onclick>
                        <onclick>Skin.SetBool(home.vertical)</onclick>
                        <onclick>Skin.SetBool(home.vertical.widgets)</onclick>
                        <onclick>Skin.SetBool(home.style.flix)</onclick>
                        <onclick condition="!Skin.HasSetting(home.show.menu.icons)">Skin.SetBool(hide.home.menu)</onclick>
                        <onclick condition="!Skin.HasSetting(home.show.menu.icons)">Skin.SetBool(hide.only.if.widgetcontainer.gets.focus)</onclick>
                        <onclick condition="Skin.HasSetting(home.show.menu.icons)">Skin.Reset(hide.home.menu)</onclick>
                        <onclick condition="Skin.HasSetting(home.show.menu.icons)">Skin.SetBool(hide.only.if.widgetcontainer.gets.focus)</onclick>
                        <onclick>Skin.SetBool(enable.blur.on.home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(reloadsetupwizard,1153,Home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(SetupWizardDirection,Next,Home)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settinghomestyle),1)">Def_Item_Selected</include>
                    </item>

                    <!-- VERTICAL MULTI WIDGETS -->

                    <item id="2">
                        <label>$LOCALIZE[31182]</label>
                        <include>Def_Reset_View_types</include>
                        <onclick>Skin.SetString(settinghomestyle,2)</onclick>
                        <onclick>Skin.SetBool(home.vertical)</onclick>
                        <onclick>Skin.SetBool(home.vertical.widgets)</onclick>
                        <onclick condition="!Skin.HasSetting(home.show.menu.icons)">Skin.SetBool(hide.home.menu)</onclick>
                        <onclick condition="!Skin.HasSetting(home.show.menu.icons)">Skin.SetBool(hide.only.if.widgetcontainer.gets.focus)</onclick>
                        <onclick condition="Skin.HasSetting(home.show.menu.icons)">Skin.Reset(hide.home.menu)</onclick>
                        <onclick condition="Skin.HasSetting(home.show.menu.icons)">Skin.SetBool(hide.only.if.widgetcontainer.gets.focus)</onclick>
                        <onclick>Skin.Reset(enable.blur.on.home)</onclick>
