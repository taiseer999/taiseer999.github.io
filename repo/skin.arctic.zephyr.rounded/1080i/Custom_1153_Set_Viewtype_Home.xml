                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(SetupWizardDirection,Next,Home)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settinghomestyle),2)">Def_Item_Selected</include>
                    </item>

                    <!-- HORIZONTAL MULTI WIDGETS FLIX -->

                    <item id="3">
                        <label>$LOCALIZE[31212] $LOCALIZE[31004]</label>
                        <include>Def_Reset_View_types</include>
                        <onclick>Skin.SetString(settinghomestyle,3)</onclick>
                        <onclick>Skin.SetBool(home.horizontal)</onclick>
                        <onclick>Skin.SetBool(home.vertical.widgets)</onclick>
                        <onclick>Skin.SetBool(home.style.flix)</onclick>
                        <onclick>Skin.Reset(hide.home.menu)</onclick>
                        <onclick>Skin.SetBool(enable.blur.on.home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(reloadsetupwizard,1153,Home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(SetupWizardDirection,Next,Home)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settinghomestyle),3)">Def_Item_Selected</include>
                    </item>

                    <!-- HORIZONTAL MULTI WIDGETS -->

                    <item id="4">
                        <label>$LOCALIZE[31212]</label>
                        <include>Def_Reset_View_types</include>
                        <onclick>Skin.SetString(settinghomestyle,4)</onclick>
                        <onclick>Skin.SetBool(home.horizontal)</onclick>
                        <onclick>Skin.SetBool(home.vertical.widgets)</onclick>
                        <onclick>Skin.Reset(hide.home.menu)</onclick>
                        <onclick>Skin.Reset(enable.blur.on.home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(reloadsetupwizard,1153,Home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(SetupWizardDirection,Next,Home)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settinghomestyle),4)">Def_Item_Selected</include>
                    </item>

                    <!-- HORIZONTAL MINIMAL AND CLEAN -->

                    <item id="5">
                        <label>$LOCALIZE[31398]</label>
                        <include>Def_Reset_View_types</include>
                        <onclick>Skin.SetString(settinghomestyle,5)</onclick>
                        <onclick>Skin.SetBool(home.horizontal)</onclick>
                        <onclick>Skin.SetBool(home.vertical.widgets)</onclick>
                        <onclick>Skin.SetBool(home.style.flix)</onclick>
                        <onclick>Skin.SetBool(home.style.horizontal.clean)</onclick>
                        <onclick>Skin.Reset(hide.home.menu)</onclick>
                        <onclick>Skin.Reset(enable.blur.on.home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(reloadsetupwizard,1153,Home)</onclick>
                        <onclick condition="$EXP[Condition_Show_Button_Setup_Wizard]">SetProperty(SetupWizardDirection,Next,Home)</onclick>
                        <onclick>Close</onclick>
                        <include condition="String.IsEqual(Skin.String(settinghomestyle),5)">Def_Item_Selected</include>
