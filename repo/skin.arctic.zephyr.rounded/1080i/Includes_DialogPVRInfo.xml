<?xml version="1.0" encoding="UTF-8"?>
<includes>
    <include name="Dialog_PVR_Info">
        <control type="group">

            <!-- LEFT POSTER SQUARE -->

            <control type="group">
                <include>Animation_Music_Info_Extended_Views_Fade_Out</include>
                <include>Animation_Dialog_Info_Left_Side_Delay_400</include>
                <include>Animation_Wiki_Fade_Out</include>

                <top>View_List_Top</top>
                <left>View_List_Side</left>
                <width>PosterH</width>
                <height>PosterH</height>

                <include>Def_Art_Full_Background_b24</include>

                <include content="Def_Art_Image">
                    <param name="visible_background_b24" value="true" />
                    <param name="colordiffuse_background" value="black" />
                    <param name="texture" value="$VAR[Image_Dialog_Info_EPG]" />
                    <param name="texture_diffuse" value="square_w640_h640_b24" />
                    <param name="aspectratio" value="keep" />
                    <param name="fallback" value="defaultpvrchannels" />
                </include>
            </control>

            <!-- RIGHT INFORMATIONS -->

            <control type="group">
                <include>Animation_Dialog_Info_Right_Side_Delay_400</include>

                <!-- CONTROL BUTTONS -->

                <control type="group">
                    <bottom>-80</bottom>
                    <include>Animation_Video_Info_Extended_Views_Fade_Out</include>
                    <include>Def_Dialog_Info_Navigation_PVR</include>
                </control>

                <!-- LABEL HEADER -->

                <control type="group">
                    <visible>!Window.IsVisible(DialogBusy.xml)</visible>

                    <include>Animation_Wiki_Fade_Out</include>
                    <include>Animation_Music_Info_Extended_Views_Fade_Out</include>

                    <top>70</top>
                    <left>DialogInfo_Square_Left</left>
                    <width>1040</width>

                    <!-- ICON -->

                    <control type="image">
                        <top>-29</top>
                        <left>-40</left>
                        <width>160</width>
                        <height>160</height>
                        <texture colordiffuse="White70">$VAR[Image_Header_Background]</texture>
                        <animation effect="fade" start="100" end="90" condition="true">Conditional</animation>
                    </control>
                    <control type="image">
                        <top>7</top>
                        <left>-4</left>
                        <width>88</width>
                        <height>88</height>
                        <texture colordiffuse="PanelWhite100" border="12">$VAR[Image_Header_Dialog_Info_Icon]</texture>
                    </control>

                    <!-- MAIN HEADER TITLE -->

                    <control type="label">
                        <left>104</left>
                        <font>LargeNew</font>
                        <description>Header Label</description>
                        <textcolor>Dark1</textcolor>
                        <label>$VAR[Label_PVR_Dialog_Info_Header_Main_Title]</label>
                        <visible>!Player.HasMedia | Skin.HasSetting(hide.furniture.nowplaying.views) | !String.IsEmpty(Window(Home).Property(VideoYoutubeIsPlaying))</visible>
                    </control>
                    <control type="label">
                        <left>104</left>
                        <width>280</width>
                        <font>LargeNew</font>
                        <description>Header Label</description>
                        <textcolor>Dark1</textcolor>
                        <label>$VAR[Label_PVR_Dialog_Info_Header_Main_Title]</label>
                        <visible>Player.HasMedia + !Skin.HasSetting(hide.furniture.nowplaying.views) + String.IsEmpty(Window(Home).Property(VideoYoutubeIsPlaying))</visible>
                    </control>

                    <!-- SUB HEADER TITLE -->

                    <control type="label">
                        <top>55</top>
                        <left>104</left>
                        <height>36</height>
                        <font>Tiny</font>
                        <textcolor>Dark1</textcolor>
                        <width>78%</width>
                        <label fallback="19055">$VAR[Label_PVR_Dialog_Info_Header_Sub_Title]</label>
                        <aligny>center</aligny>
                        <visible>!Player.HasMedia | Skin.HasSetting(hide.furniture.nowplaying.views)</visible>
                    </control>
                    <control type="label">
                        <top>55</top>
                        <left>104</left>
                        <width>280</width>
                        <height>36</height>
                        <font>Tiny</font>
                        <textcolor>Dark1</textcolor>
                        <width>78%</width>
                        <label fallback="19055">$VAR[Label_PVR_Dialog_Info_Header_Sub_Title]</label>
                        <aligny>center</aligny>
                        <visible>Player.HasMedia + !Skin.HasSetting(hide.furniture.nowplaying.views)</visible>
                    </control>
                </control>

                <!-- CLEARLOGO -->

                <control type="group" description="clearlogo">
                    <visible>Skin.HasSetting(show.dialog.info.clearlogo.video)</visible>
                    <visible>ControlGroup(9000).HasFocus() | !String.IsEmpty(Window(Home).Property(title_tempo)) | !String.IsEmpty(Window(Home).Property(VideoYoutubeIsPlaying))</visible>

                    <include>Animation_Wiki_Fade_Out</include>
                    <include>Animation_Video_Info_Extended_Views_Fade_Out</include>

                    <include>Animation_Dialog_Info_Fade_In_250_Delay_200</include>
                    <include>Animation_Dialog_Video_Info_Clearlogo_Fade_Out</include>

                    <control type="image" description="clearlogo">
                        <centertop>264</centertop>
                        <right>View_List_Side</right>
                        <height>ClearLogoMaxHeight</height>
                        <width>ClearLogoMaxWidth</width>
                        <fadetime>ClearArtFadetime</fadetime>
                        <aspectratio align="right">keep</aspectratio>
                        <texture background="true">$VAR[Image_Crop_ClearLogo]</texture>
                    </control>
                </control>

                <!-- FOOTER LABEL -->

                <control type="label">
                    <right>83</right>
                    <bottom>100</bottom>
                    <height>50</height>
                    <font>Mini</font>
                    <scroll>false</scroll>
                    <textcolor>Dark3</textcolor>
                    <label>$VAR[Label_Dialog_Info_Footer_Tip_Right]</label>
                    <aligny>center</aligny>
                    <align>right</align>
                    <visible>ControlGroup(9000).HasFocus()</visible>
                    <include>Animation_Common_Fade_In</include>
                    <include>Animation_Common_Fade_Out</include>
                </control>

                <!-- INFORMATION -->

                <control type="group">
                    <include>Animation_Video_Info_Extended_Views_Fade_Out</include>
                    <include>Animation_Dialog_Info_Fade_In_250_Delay_200</include>
                    <include>Animation_Dialog_Info_Fade_Out_150</include>

                    <top>DialogInfo_Top</top>
                    <left>ListSquareX</left>
                    <right>View_List_Side</right>
                    <bottom>224</bottom>

                    <control type="grouplist">
                        <left>30</left>
                        <right>0</right>
                        <itemgap>0</itemgap>
                        <include content="Def_Dialog_Square_Info_Line">
                            <param name="label" value="$LOCALIZE[2050]" />
                            <param name="value" value="$VAR[Label_Duration_Time_Check]" />
                        </include>
                        <include content="Def_Dialog_Square_Info_Line">
                            <param name="label" value="$LOCALIZE[19126]" />
                            <param name="value" value="$INFO[ListItem.StartDate] - $INFO[ListItem.StartTime]" />
                        </include>
                        <include content="Def_Dialog_Square_Info_Line">
                            <param name="label" value="$LOCALIZE[19127]" />
                            <param name="value" value="$INFO[ListItem.EndDate] - $INFO[ListItem.EndTime]" />
                        </include>
                        <include content="Def_Dialog_Square_Info_Line">
                            <param name="label" value="$LOCALIZE[515]" />
                            <param name="value" value="$INFO[ListItem.Genre]" />
                        </include>
                        <control type="group">
                            <height>38</height>
                        </control>
                        <control type="group">
                            <height>auto</height>
                            <width>100%</width>
                            <control type="textbox">
                                <left>0</left>
                                <right>0</right>
                                <height>425</height>
                                <font>Tiny</font>
                                <textcolor>Dark2</textcolor>
                                <align>left</align>
                                <label>$INFO[ListItem.Plot]$INFO[Window(Home).Property(ResetScroll)]</label>
                                <aligny>top</aligny>
                            </control>
                        </control>
                    </control>
                </control>
            </control>
        </control>
    </include>
</includes>
