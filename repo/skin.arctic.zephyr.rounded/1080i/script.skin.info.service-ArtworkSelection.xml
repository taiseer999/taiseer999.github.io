<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <defaultcontrol always="true">100</defaultcontrol>
    <!--
    CONTROL IDs:
      100 - Artwork list control (displays available options, click to select)
      201 - Skip button
      202 - Cancel button
      203 - Multi-Art button (visibility controlled by show_multiart property)
      204 - Change Language button (visibility controlled by show_change_language property)
      205 - Sort button (toggles between popularity and resolution sort modes)
      206 - Source button (toggles between all/TMDB/Fanart.tv filtering)

    WINDOW PROPERTIES use $INFO[Window.Property(name)]:
      - heading: Title (e.g., "The Matrix")
      - year: Release year
      - mediatype: Media type (movie, tvshow, etc.)
      - arttype: Art type being selected (e.g., "Poster", "Fanart")
      - state: State text ("Missing artwork" / "Replace existing artwork" / "" for single)
      - hascurrentart: "true" or "false" - whether item already has this art type
      - currentarturl: URL of current artwork (if any)
      - count: Smart display string ("58 available" or "24 of 58 available (English)")
      - count_filtered: Raw number of filtered items (string)
      - count_total: Raw number of total items (string)
      - language: Display name for current language filter (e.g., "English")
      - language_short: Current language filter code (e.g., "en")
      - show_change_language: "true" or "false" - whether to show Change Language button
      - show_multiart: "true" or "false" - multi-art button availability

    LISTITEM PROPERTIES use $INFO[ListItem.Property(name)]:
      - is_current: "true" if this artwork is currently assigned
      - dimensions: Width x Height (e.g., "1920x1080")
      - width: Image width in pixels
      - height: Image height in pixels
      - source: Source name (e.g., "TMDB", "fanart.tv")
      - language: Display name for this artwork's language (e.g., "English")
      - language_short: Language code for this artwork (e.g., "en")
      - season: Season number (when available)
      - fullurl: Full resolution image URL
      - index: 0-based index for selection tracking
    -->
