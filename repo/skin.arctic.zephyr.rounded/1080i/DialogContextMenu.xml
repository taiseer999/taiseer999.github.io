    <onload condition="!String.IsEmpty(Window(Home).Property(TMDbHelper.ListItem.base_label))">RunPlugin("plugin://script.skinvariables/?info=get_encoded_string&amp;unencoded_paths=true&amp;window_id=Home&amp;window_prop=Encoded.ListItem.Label&amp;&amp;$INFO[Window(Home).Property(TMDbHelper.ListItem.base_label)]")</onload>

