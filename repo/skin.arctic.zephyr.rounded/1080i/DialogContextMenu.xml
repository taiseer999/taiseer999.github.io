                <onclick condition="![Window.IsActive(movieinformation) + !String.IsEmpty(Window(Home).Property(moviecontent))] + ![Window.IsActive(musicinformation) | Window.IsActive(songinformation)] + $EXP[Exp_ContextMenu_Show_Info]">Dialog.Close(contextmenu)</onclick>
                <onclick condition="![Window.IsActive(movieinformation) + !String.IsEmpty(Window(Home).Property(moviecontent))] + ![Window.IsActive(musicinformation) | Window.IsActive(songinformation)] + $EXP[Exp_ContextMenu_Show_Info]">AlarmClock(Launch_Search,$VAR[Path_ContextParams_Path_Info],00:01,silent)</onclick>

