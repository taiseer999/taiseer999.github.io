    <include name="Object_Arrows_Textbox_Navigation">
        <param name="top" value="$PARAM[top]" />
        <param name="bottom" value="$PARAM[bottom]" />
        <param name="left" value="$PARAM[left]" />
        <param name="idtextbox" default="$PARAM[idtextbox]" />
        <param name="colordiffuse" value="$PARAM[colordiffuse]" default="Dark2" />
        <param name="colordiffuse_background" value="$PARAM[colordiffuse_background]" default="Dark4" />

        <param name="visible" value="$PARAM[visible]" default="true" />

        <definition>
            <control type="group">
                <visible>Container($PARAM[idtextbox]).HasPrevious + $PARAM[visible]</visible>
                <include>Animation_Common_Fade_In</include>
                <include>Animation_Common_Fade_Out</include>

                <top>$PARAM[top]</top>
                <left>$PARAM[left]</left>

                <include content="Object_Arrows_Up">
                    <param name="colordiffuse" value="$PARAM[colordiffuse]" />
                    <param name="colordiffuse_background" value="$PARAM[colordiffuse_background]" />
                </include>
            </control>
            <control type="group">
                <visible>Container($PARAM[idtextbox]).HasNext + $PARAM[visible]</visible>
                <include>Animation_Common_Fade_In</include>
                <include>Animation_Common_Fade_Out</include>

                <top>$PARAM[bottom]</top>
                <left>$PARAM[left]</left>

                <include content="Object_Arrows_Down">
                    <param name="colordiffuse" value="$PARAM[colordiffuse]" />
                    <param name="colordiffuse_background" value="$PARAM[colordiffuse_background]" />
                </include>
            </control>
        </definition>
    </include>

    <include name="Object_Arrows_Up">
