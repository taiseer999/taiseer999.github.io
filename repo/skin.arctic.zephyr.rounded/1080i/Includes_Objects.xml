                </control>
                <control type="image">
                    <top>$PARAM[arrow_bottom]</top>
                    <centerleft>$PARAM[arrow_centerleft]</centerleft>
                    <include>Def_Arrow_Size</include>
                    <include content="Texture_Arrow_Down"><param name="colordiffuse" value="$PARAM[colordiffuse]" /></include>
                </control>
            </control>
        </definition>
    </include>

    <include name="Object_Arrows_DialogInfo_Navigation">
        <param name="centerbottom" value="$PARAM[centerbottom]" default="257" />
        <param name="centerleft" value="$PARAM[centerleft]" default="550" />
