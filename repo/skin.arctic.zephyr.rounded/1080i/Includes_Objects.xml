    <include name="Object_Arrows_Down">
        <param name="colordiffuse" value="$PARAM[colordiffuse]" default="Dark2" />
        <param name="colordiffuse_background" value="$PARAM[colordiffuse_background]" default="Dark4" />

        <definition>
            <control type="image" description="button back">
                <top>-7</top>
                <left>-12</left>
                <width>40</width>
                <height>40</height>
                <texture border="0" colordiffuse="$PARAM[colordiffuse_background]">common/circle80.png</texture>
            </control>
            <control type="image">
                <top>0</top>
                <include>Def_Arrow_Size</include>
                <include content="Texture_Arrow_Down"><param name="colordiffuse" value="$PARAM[colordiffuse]" /></include>
            </control>
            <control type="image">
