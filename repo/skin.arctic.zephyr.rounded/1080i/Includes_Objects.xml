    <!-- SPINNER -->

    <include name="Object_Spinner_Busy">
        <param name="show_label_spinner" value="$PARAM[show_label_spinner]" default="true" />
        <param name="label_spinner" value="$PARAM[label_spinner]" default="$LOCALIZE[31546]..." />

        <param name="textcolor"  value="$PARAM[textcolor]" default="Dark2" />
        <param name="centertop" value="$PARAM[centertop]" default="54" />
        <param name="centerleft" value="$PARAM[centerleft]" default="54" />

        <param name="size" default="100" />
        <param name="texture_circle" default="dialog/loading-back.png" />
        <param name="colordiffuse_circle" default="PanelWhite100" />

        <param name="icon" default="special://skin/extras/icons/kodi.png" />
        <param name="colordiffuse_icon" default="PanelWhite70" />

        <param name="has_spinner" default="true" />
        <param name="spin_spinner" default="true" />
        <param name="has_progress" default="false" />
        <param name="spin_progress" default="false" />

        <param name="progress" default="Control.GetLabel(32)" />
        <param name="progress_id" default="32" />

        <param name="visible" default="true" />
        <definition>
            <control type="group">
                <visible>$PARAM[visible]</visible>
                <nested />

                <centertop>$PARAM[centertop]</centertop>
                <centerleft>$PARAM[centerleft]</centerleft>
                <width>$PARAM[size]</width>
                <height>$PARAM[size]</height>

                <!-- CIRCLE -->

                <control type="image" description="Back">
                    <aspectratio align="center" aligny="center">keep</aspectratio>
                    <texture>$PARAM[texture_circle]</texture>
                    <colordiffuse>$PARAM[colordiffuse_circle]</colordiffuse>
                </control>

                <!-- ICON -->

                <control type="image" description="Icon">
                    <bordersize>30</bordersize>
                    <aspectratio align="center" aligny="center">keep</aspectratio>
                    <texture>$PARAM[icon]</texture>
                    <colordiffuse>$PARAM[colordiffuse_icon]</colordiffuse>
                </control>

                <!-- SPINNER -->

                <include content="Object_Control" condition="$PARAM[has_spinner]">
                    <param name="control" value="group" />
                    <description>Busy animation</description>
                    <animation effect="rotate" condition="$PARAM[spin_spinner]" start="360" end="0" loop="true" time="1000" center="auto">Conditional</animation>
                    <control type="image">
                        <texture colordiffuse="$VAR[Color_Focus]">dialog/loading-spinner.png</texture>
                        <aspectratio>keep</aspectratio>
                    </control>
                    <control type="image">
                        <texture colordiffuse="$VAR[Color_Focus]">dialog/loading-spinner.png</texture>
                        <aspectratio>keep</aspectratio>
                        <animation effect="fade" condition="$PARAM[spin_spinner]" start="0" end="100" pulse="true" time="1000">Conditional</animation>
                    </control>
                </include>

                <!-- PROGRESS -->

                <include content="Object_Control" condition="$PARAM[has_progress]">
                    <param name="control" value="group" />
                    <description>Busy animation</description>
                    <animation effect="rotate" condition="$PARAM[spin_progress]" start="360" end="0" loop="true" time="2000" center="auto">Conditional</animation>
                    <control type="image">
                        <texture colordiffuse="$VAR[Color_Focus]">$INFO[$PARAM[progress],progress/circle_info/p,.png]</texture>
                        <aspectratio align="center" aligny="center">keep</aspectratio>
                    </control>
                    <control type="image">
                        <texture colordiffuse="$VAR[Color_Focus]">$INFO[$PARAM[progress],progress/circle_info/p,.png]</texture>
                        <animation effect="fade" end="66" condition="true">Conditional</animation>
                        <aspectratio align="center" aligny="center">keep</aspectratio>
                    </control>
                </include>

                <!-- LABEL -->

                <include content="Object_Control" condition="$PARAM[show_label_spinner]">
                    <param name="control" value="label" />
                    <bottom>-40</bottom>
                    <height>40</height>
                    <width>600</width>
                    <centerleft>50%</centerleft>
                    <align>center</align>
                    <label>$PARAM[label_spinner]</label>
                    <font>Tiny</font>
                    <textcolor>$PARAM[textcolor]</textcolor>
                </include>
            </control>
        </definition>
    </include>

    <include name="Object_Spinner_Pause">
        <param name="visible" default="Player.Paused" />
        <param name="centerleft" default="54" />
        <param name="centertop" default="54" />
        <param name="size" default="100" />
        <definition>
            <control type="group">
                <visible>$PARAM[visible]</visible>

                <centertop>$PARAM[centertop]</centertop>
                <centerleft>$PARAM[centerleft]</centerleft>

                <width>$PARAM[size]</width>
                <height>$PARAM[size]</height>

                <!-- BACKGROUND -->

                <control type="image" description="Back">
                    <left>0</left>
                    <centertop>50%</centertop>
                    <width>100</width>
                    <height>100</height>
                    <aspectratio align="center" aligny="center">keep</aspectratio>
                    <texture>dialog/loading-back.png</texture>
                    <animation effect="fade" start="0" end="100" time="150">VisibleChange</animation>
                </control>

                <!-- PAUSED -->

                <control type="image" description="Pause">
                    <left>0</left>
                    <centertop>50%</centertop>
                    <width>100</width>
                    <height>100</height>
                    <aspectratio align="center" aligny="center">keep</aspectratio>
                    <texture colordiffuse="FFFFFFFF">nowplaying/pause.png</texture>
                    <animation effect="fade" start="0" end="100" time="150">VisibleChange</animation>
                    <visible>Player.Paused</visible>
                </control>

                <!-- PLAYING -->

                <control type="image" description="Pause">
                    <left>0</left>
                    <centertop>50%</centertop>
                    <width>100</width>
                    <height>100</height>
                    <aspectratio align="center" aligny="center">keep</aspectratio>
                    <texture colordiffuse="FFFFFFFF">nowplaying/play.png</texture>
                    <animation effect="fade" start="0" end="100" time="150">VisibleChange</animation>
                    <include>Animation_Rotate_Icon_Play</include>
                    <visible>Player.Playing</visible>
                </control>

                <!-- PROGRESS -->

                <control type="progress" id="933">
                    <texturebg />
                    <lefttexture />
                    <midtexture />
                    <righttexture />
                    <info>Player.Progress</info>
                    <visible>false</visible>
                </control>
                <control type="image">
                    <left>0</left>
                    <centertop>50%</centertop>
                    <width>100</width>
                    <height>100</height>
                    <texture colordiffuse="$VAR[Color_Loading_Spinner]">$INFO[Control.GetLabel(933),progress/circle_info/p,.png]</texture>
                    <aspectratio align="center">keep</aspectratio>
                    <visible>!String.IsEmpty(Player.Duration)</visible>
                </control>
            </control>
        </definition>
    </include>

    <include name="Object_Spinner_Progress">
        <visible>$PARAM[visible]</visible>
        <control type="image" description="Back">
            <left>0</left>
            <centertop>50%</centertop>
            <width>100</width>
            <height>100</height>
            <aspectratio align="center" aligny="center">keep</aspectratio>
            <texture colordiffuse="Dark2">dialog/loading-back.png</texture>
            <animation effect="fade" start="0" end="100" time="150">VisibleChange</animation>
        </control>
        <control type="image" description="Play">
            <left>0</left>
            <centertop>50%</centertop>
            <width>100</width>
            <height>100</height>
            <aspectratio align="center" aligny="center">keep</aspectratio>
            <texture colordiffuse="Dark1">nowplaying/play.png</texture>
            <animation effect="fade" start="0" end="100" time="150">VisibleChange</animation>
            <visible>!Player.Paused + !Player.Forwarding + !Player.Forwarding</visible>
            <include>$PARAM[animation]</include>
        </control>
        <control type="image" description="Pause">
            <left>0</left>
            <centertop>50%</centertop>
            <width>100</width>
            <height>100</height>
            <aspectratio align="center" aligny="center">keep</aspectratio>
            <texture colordiffuse="Dark1">nowplaying/pause.png</texture>
            <animation effect="fade" start="0" end="100" time="150">VisibleChange</animation>
            <visible>Player.Paused</visible>
        </control>
        <control type="image" description="Forwarding">
            <left>-3</left>
            <centertop>50%</centertop>
            <width>100</width>
            <height>100</height>
            <aspectratio align="center" aligny="center">keep</aspectratio>
            <texture colordiffuse="Dark1">nowplaying/ff.png</texture>
            <animation effect="fade" start="0" end="100" time="150">VisibleChange</animation>
            <visible>Player.Forwarding</visible>
        </control>
        <control type="image" description="Rewinding">
            <left>-3</left>
            <centertop>50%</centertop>
            <width>100</width>
            <height>100</height>
            <aspectratio align="center" aligny="center">keep</aspectratio>
            <texture colordiffuse="Dark1">nowplaying/rw.png</texture>
            <animation effect="fade" start="0" end="100" time="150">VisibleChange</animation>
            <visible>Player.Rewinding</visible>
        </control>
        <control type="progress" id="$PARAM[id]">
            <texturebg />
            <lefttexture />
            <midtexture />
            <righttexture />
            <info>$PARAM[info]</info>
            <visible>false</visible>
        </control>
        <control type="image">
            <left>0</left>
            <centertop>50%</centertop>
            <width>100</width>
            <height>100</height>
            <texture colordiffuse="$VAR[Color_Loading_Spinner]">$INFO[Control.GetLabel($PARAM[id]),progress/circle_info/p,.png]</texture>
            <aspectratio align="center">keep</aspectratio>
        </control>
    </include>

    <!-- SCROLLBAR -->

    <include name="Object_Scrollbar_Dialog_Vertical">
        <param name="height" value="$PARAM[height]" default="700" />
        <param name="top" value="$PARAM[top]" default="112" />
        <param name="centerright" value="$PARAM[centerright]" default="360" />
        <param name="colordiffuse_texturesliderbackground" value="$PARAM[colordiffuse_texturesliderbackground]" default="Dark4" />
        <param name="colordiffuse_texturesliderbar" default="Dark3" />
        <param name="texturesliderbarfocus_colordiffuse" value="$PARAM[texturesliderbarfocus_colordiffuse]" default="$VAR[Color_Focus]" />
        <param name="animation_fade_hide" value="$PARAM[animation_fade_hide]" default="true" />
        <param name="condition_on_left" value="$PARAM[condition_on_left]" default="true" />
        <param name="visible" value="$PARAM[visible]" default="true" />

        <definition>
            <control type="scrollbar" id="$PARAM[scrollid]">
                <visible>$PARAM[visible]</visible>

                <top>$PARAM[top]</top>
                <height>$PARAM[height]</height>
                <centerright>$PARAM[centerright]</centerright>
                <width>8</width>

                <onleft condition="$PARAM[condition_on_left]">$PARAM[onleft]</onleft>
                <onleft condition="!$PARAM[condition_on_left]">$PARAM[onleft2]</onleft>
                <onright>$PARAM[onright]</onright>
                <onback>$PARAM[onback]</onback>

                <orientation>vertical</orientation>
                <showonepage>false</showonepage>

                <texturesliderbackground border="4" colordiffuse="$PARAM[colordiffuse_texturesliderbackground]">scrollbar/scrollv.png</texturesliderbackground>
                <texturesliderbar border="4" colordiffuse="$PARAM[colordiffuse_texturesliderbar]">scrollbar/scrollv.png</texturesliderbar>
                <texturesliderbarfocus border="4" colordiffuse="$PARAM[texturesliderbarfocus_colordiffuse]">scrollbar/scrollv.png</texturesliderbarfocus>

                <animation effect="fade" start="100" end="0" time="400" condition="!Control.HasFocus($PARAM[scrollid]) + !Container.Scrolling + $PARAM[animation_fade_hide]">Conditional</animation>
            </control>
        </definition>
    </include>

