    <include name="Object_Arrows_Dialog_Vertical">
        <param name="arrow_top" default="-24" />
        <param name="arrow_bottom" default="839" />
        <param name="arrow_centerleft" default="50%" />

        <param name="colordiffuse" default="White100" />
        <param name="container_id" default="$PARAM[container_id]" />

        <param name="visible" default="true" />

        <definition>
