
<window>

<defaultcontrol always="true">100</defaultcontrol>

<controls>

<control type="image">
    <left>0</left>
    <top>0</top>
    <width>1920</width>
    <height>1080</height>
    <texture>special://home/addons/script.portal/resources/media/background.jpg</texture>
    <aspectratio>stretch</aspectratio>
</control>

<control type="image">
    <left>0</left>
    <top>0</top>
    <width>1920</width>
    <height>1080</height>
    <colordiffuse>B0000000</colordiffuse>
    <texture>white.png</texture>
</control>

<control type="label">
    <left>60</left>
    <top>35</top>
    <width>1200</width>
    <height>60</height>
    <font>font30_title</font>
    <textcolor>FFFFFFFF</textcolor>
    <label>SKIN SELECTION</label>
</control>

<control type="panel" id="100">

    <left>60</left>
    <top>150</top>
    <width>1800</width>
    <height>850</height>

    <itemlayout width="520" height="340">

        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>480</width>
            <height>320</height>
            <colordiffuse>D0000000</colordiffuse>
            <texture>white.png</texture>
        </control>

        <control type="image">
            <left>10</left>
            <top>10</top>
            <width>460</width>
            <height>250</height>
            <texture>$INFO[ListItem.Art(thumb)]</texture>
            <aspectratio>scale</aspectratio>
        </control>

        <control type="label">
            <left>15</left>
            <top>270</top>
            <width>450</width>
            <height>40</height>
            <font>font20</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>$INFO[ListItem.Label]</label>
        </control>

    </itemlayout>

    <focusedlayout width="520" height="340">

        <control type="image">
            <left>-5</left>
            <top>-5</top>
            <width>490</width>
            <height>330</height>
            <colordiffuse>FF303030</colordiffuse>
            <texture>white.png</texture>
        </control>

        <control type="image">
            <left>10</left>
            <top>10</top>
            <width>470</width>
            <height>260</height>
            <texture>$INFO[ListItem.Art(thumb)]</texture>
            <aspectratio>scale</aspectratio>
        </control>

        <control type="label">
            <left>15</left>
            <top>280</top>
            <width>450</width>
            <height>40</height>
            <font>font24_title</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>$INFO[ListItem.Label]</label>
        </control>

    </focusedlayout>

</control>

</controls>

</window>
