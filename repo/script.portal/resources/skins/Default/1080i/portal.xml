<window>

<defaultcontrol always="true">100</defaultcontrol>

<controls>

<!-- ── Layer 1: background photo ───────────────────────────────────────── -->
<control type="image">
    <left>0</left>
    <top>0</top>
    <width>1920</width>
    <height>1080</height>
    <texture>$INFO[Window.Property(background)]</texture>
    <aspectratio>stretch</aspectratio>
</control>

<!-- ── Layer 2: heavy dark vignette so text/cards always readable ───────── -->
<control type="image">
    <left>0</left>
    <top>0</top>
    <width>1920</width>
    <height>1080</height>
    <colordiffuse>CC000000</colordiffuse>
    <texture>white.png</texture>
</control>

<!-- ── Layer 3: top header bar (dark navy, semi-transparent) ────────────── -->
<control type="image">
    <left>0</left>
    <top>0</top>
    <width>1920</width>
    <height>120</height>
    <colordiffuse>E0101828</colordiffuse>
    <texture>white.png</texture>
</control>

<!-- ── Layer 4: blue accent line along the very top edge ────────────────── -->
<control type="image">
    <left>0</left>
    <top>0</top>
    <width>1920</width>
    <height>4</height>
    <colordiffuse>FF00AAFF</colordiffuse>
    <texture>white.png</texture>
</control>

<!-- ── Layer 5: separator line below the header bar ────────────────────── -->
<control type="image">
    <left>0</left>
    <top>120</top>
    <width>1920</width>
    <height>2</height>
    <colordiffuse>8000AAFF</colordiffuse>
    <texture>white.png</texture>
</control>

<!-- ── Layer 6: bottom status bar ───────────────────────────────────────── -->
<control type="image">
    <left>0</left>
    <top>1040</top>
    <width>1920</width>
    <height>40</height>
    <colordiffuse>D0101828</colordiffuse>
    <texture>white.png</texture>
</control>

<!-- ── Layer 7: thin blue accent line above the bottom bar ──────────────── -->
<control type="image">
    <left>0</left>
    <top>1040</top>
    <width>1920</width>
    <height>2</height>
    <colordiffuse>8000AAFF</colordiffuse>
    <texture>white.png</texture>
</control>

<!-- ── Layer 8: left-side blue edge glow strip ──────────────────────────── -->
<control type="image">
    <left>0</left>
    <top>0</top>
    <width>6</width>
    <height>1080</height>
    <colordiffuse>FF00AAFF</colordiffuse>
    <texture>white.png</texture>
</control>

<!-- ── Title ─────────────────────────────────────────────────────────────── -->
<control type="label">
    <left>60</left>
    <top>35</top>
    <width>1200</width>
    <height>60</height>
    <font>font30_title</font>
    <textcolor>FFFFFFFF</textcolor>
    <shadowcolor>CC000000</shadowcolor>
    <label>SKIN SELECTION</label>
</control>

<!-- ── Decorative short accent line under the title ─────────────────────── -->
<control type="image">
    <left>60</left>
    <top>108</top>
    <width>300</width>
    <height>3</height>
    <colordiffuse>FF00AAFF</colordiffuse>
    <texture>white.png</texture>
</control>

<!-- ── Hint label in the bottom bar ─────────────────────────────────────── -->
<control type="label">
    <left>60</left>
    <top>1047</top>
    <width>1800</width>
    <height>30</height>
    <font>font12</font>
    <textcolor>A0FFFFFF</textcolor>
    <label>Select a skin to install · Press Back to exit</label>
</control>

<!-- ── Grid panel ────────────────────────────────────────────────────────── -->
<control type="panel" id="100">

    <left>60</left>
    <top>140</top>
    <width>1800</width>
    <height>890</height>

    <!-- ── Unselected card layout ──────────────────────────────────────── -->
    <itemlayout width="520" height="340">

        <!-- card background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>480</width>
            <height>320</height>
            <colordiffuse>D0000000</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- thumbnail -->
        <control type="image">
            <left>10</left>
            <top>10</top>
            <width>460</width>
            <height>250</height>
            <texture>$INFO[ListItem.Art(thumb)]</texture>
            <aspectratio>scale</aspectratio>
        </control>

        <!-- dark overlay on thumbnail to dim unselected -->
        <control type="image">
            <left>10</left>
            <top>10</top>
            <width>460</width>
            <height>250</height>
            <colordiffuse>55000000</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- label bar background -->
        <control type="image">
            <left>0</left>
            <top>268</top>
            <width>480</width>
            <height>52</height>
            <colordiffuse>CC101828</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- skin name label -->
        <control type="label">
            <left>15</left>
            <top>278</top>
            <width>450</width>
            <height>40</height>
            <font>font20</font>
            <textcolor>99FFFFFF</textcolor>
            <label>$INFO[ListItem.Label]</label>
        </control>

    </itemlayout>

    <!-- ── Focused card layout ─────────────────────────────────────────── -->
    <focusedlayout width="520" height="340">

        <!-- 1. outermost glow: large soft blue halo -->
        <control type="image">
            <left>-16</left>
            <top>-16</top>
            <width>512</width>
            <height>352</height>
            <colordiffuse>4400AAFF</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- 2. outer accent border: solid bright blue rim -->
        <control type="image">
            <left>-6</left>
            <top>-6</top>
            <width>492</width>
            <height>332</height>
            <colordiffuse>FF00AAFF</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- 3. inner border: slightly darker navy ring -->
        <control type="image">
            <left>-2</left>
            <top>-2</top>
            <width>484</width>
            <height>324</height>
            <colordiffuse>FF0D2137</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- 4. card background: deep navy -->
        <control type="image">
            <left>2</left>
            <top>2</top>
            <width>476</width>
            <height>316</height>
            <colordiffuse>FF111827</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- 5. thumbnail: full brightness, slightly larger -->
        <control type="image">
            <left>8</left>
            <top>8</top>
            <width>460</width>
            <height>254</height>
            <texture>$INFO[ListItem.Art(thumb)]</texture>
            <aspectratio>scale</aspectratio>
        </control>

        <!-- 6. very subtle blue tint over thumbnail -->
        <control type="image">
            <left>8</left>
            <top>8</top>
            <width>460</width>
            <height>254</height>
            <colordiffuse>0D0055FF</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- 7. top edge highlight line on thumbnail (top shimmer) -->
        <control type="image">
            <left>8</left>
            <top>8</top>
            <width>460</width>
            <height>3</height>
            <colordiffuse>CC00AAFF</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- 8. label bar: vivid blue, full width -->
        <control type="image">
            <left>2</left>
            <top>268</top>
            <width>476</width>
            <height>50</height>
            <colordiffuse>FF0077CC</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- 9. label bar top highlight line -->
        <control type="image">
            <left>2</left>
            <top>268</top>
            <width>476</width>
            <height>2</height>
            <colordiffuse>FF00DDFF</colordiffuse>
            <texture>white.png</texture>
        </control>

        <!-- 10. skin name label: bright white, bold font -->
        <control type="label">
            <left>12</left>
            <top>276</top>
            <width>452</width>
            <height>40</height>
            <font>font24_title</font>
            <textcolor>FFFFFFFF</textcolor>
            <shadowcolor>FF000000</shadowcolor>
            <label>$INFO[ListItem.Label]</label>
        </control>

        <!-- 11. small "▶ SELECT" hint on the right side of label bar -->
        <control type="label">
            <left>12</left>
            <top>276</top>
            <width>452</width>
            <height>40</height>
            <font>font12</font>
            <textcolor>limegreen</textcolor>
            <align>right</align>
            <label>OK TO INSTALL ↓</label>
        </control>

    </focusedlayout>

</control>

</controls>

</window>
