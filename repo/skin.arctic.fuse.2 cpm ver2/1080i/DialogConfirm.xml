<?xml version="1.0" encoding="UTF-8"?>
<window>

    <controls>
        <!-- <include>Dialog_Confirm</include> -->
        <include content="Object_Hidden_Button">
            <param name="id">10</param>
            <onfocus condition="Control.IsVisible(11)">SetFocus(9010)</onfocus>
            <onfocus condition="!Control.IsVisible(11)">SetFocus(9110)</onfocus>
        </include>
        <include content="Object_Hidden_Button">
            <param name="id">11</param>
            <onfocus condition="Control.IsVisible(10)">SetFocus(9011)</onfocus>
            <onfocus condition="!Control.IsVisible(10)">SetFocus(9111)</onfocus>
        </include>
        <include content="Object_Hidden_Button">
            <param name="id">12</param>
            <onfocus>SetFocus(9012)</onfocus>
        </include>


        <include>Dialog_Dim_Overlay</include>

        <control type="group">
            <include>Animation_Right_Delay</include>

            <include>Dimension_DialogMiniMenu</include>
            <include content="Dialog_Foreground_Side">
                <param name="dialog_size">Dimension_DialogMiniMenu</param>
                <param name="lines_right">0</param>
                <param name="topline">true</param>
                <param name="subline">true</param>
            </include>

            <control type="group">
                <include content="Dialog_Head">
                    <param name="id">9999</param>
                    <param name="label">$VAR[Label_DialogConfirm_Heading]</param>
                </include>
                <include>Dialog_Head_CloseButton</include>

                <!-- Content -->
                <control type="group">
                    <include>Dimension_Dialog_Body</include>

                    <control type="group" id="7000">
                        <include>Dimension_Dialog_Body_Group</include>

                        <control type="grouplist">
                            <top>0</top>
                            <bottom>280</bottom>
                            <orientation>vertical</orientation>
                            <left>20</left>
                            <right>20</right>
                            <itemgap>20</itemgap>

                            <control type="textbox" id="1">
                                <font>font_midi_bold</font>
                                <textcolor>dialog_fg_90</textcolor>
                                <height min="80">auto</height>
                                <aligny>center</aligny>
                            </control>

                            <control type="textbox" id="9">
                                <font>font_main_plot</font>
                                <textcolor>dialog_fg_70</textcolor>
                                <height>auto</height>
                            </control>
                        </control>

                        <control type="group">
                            <bottom>0</bottom>
                            <height>130</height>
                            <control type="image">
                                <visible>Control.IsVisible(20)</visible>
                                <texture colordiffuse="$VAR[Color_DialogBorder]" border="40">common/menu.png</texture>
                            </control>
                            <control type="progress" id="20">
                                <description>Progressbar</description>
                                <info>System.Progressbar</info>
                                <texturebg colordiffuse="00ffffff" border="40,0,40,0">common/menu.png</texturebg>
                                <midtexture colordiffuse="$VAR[ColorHighlight]" border="100,40,100,40">common/menu.png</midtexture>
                            </control>
                            <control type="progress">
                                <visible>Control.IsVisible(20)</visible>
                                <description>Progressbar</description>
                                <info>System.Progressbar</info>
                                <texturebg colordiffuse="00ffffff" border="40,0,40,0">common/menu.png</texturebg>
                                <midtexture colordiffuse="$VAR[ColorGradient]" border="100,40,100,40" diffuse="progress/diffuse.png">common/menu.png</midtexture>
                                <include content="Defs_Progress_Colorfade">
                                    <param name="id">20</param>
                                </include>
                            </control>
                        </control>

                        <control type="grouplist">
                            <orientation>vertical</orientation>
                            <align>bottom</align>
                            <itemgap>20</itemgap>

                            <control type="group">
                                <height>20</height>
                                <left>20</left>
                                <right>20</right>
                                <control type="image">
                                    <height>1</height>
                                    <centerbottom>0</centerbottom>
                                    <texture colordiffuse="$VAR[Color_DialogBorder]">common/white.png</texture>
                                </control>
                            </control>

                            <control type="group" id="9200">
                                <height>130</height>
                                <visible>Control.IsVisible(10) + Control.IsVisible(11)</visible>
                                <control type="group">
                                    <width>50%</width>
                                    <include content="Dialog_Special_Button">
                                        <param name="id">9010</param>
                                        <param name="sublabel">$INFO[Control.GetLabel(10)]</param>
                                        <param name="icon">$VAR[Image_DialogConfirm_10]</param>
                                        <param name="icon_bordersize">4</param>
                                        <param name="icon_withtext">true</param>
                                        <control type="button" id="9010">
                                            <include>defs_dialog_button</include>
                                            <onclick>SendClick(10)</onclick>
                                            <ondown condition="Control.IsVisible(12)">12</ondown>
                                            <onright>9011</onright>
                                        </control>
                                        <right>10</right>
                                    </include>
                                </control>
                                <control type="group">
                                    <width>50%</width>
                                    <right>0</right>
                                    <include content="Dialog_Special_Button">
                                        <param name="id">9011</param>
                                        <param name="sublabel">$INFO[Control.GetLabel(11)]</param>
                                        <param name="icon">$VAR[Image_DialogConfirm_11]</param>
                                        <param name="icon_bordersize">4</param>
                                        <param name="icon_withtext">true</param>
                                        <control type="button" id="9011">
                                            <include>defs_dialog_button</include>
                                            <onclick>SendClick(11)</onclick>
                                            <ondown condition="Control.IsVisible(12)">12</ondown>
                                            <onleft>9010</onleft>
                                        </control>
                                        <left>10</left>
                                    </include>
                                </control>
                            </control>

                            <control type="group">
                                <height>130</height>
                                <visible>Control.IsVisible(10) + !Control.IsVisible(11)</visible>
                                <include content="Dialog_Special_Button">
                                    <param name="id">9110</param>
                                    <param name="sublabel">$INFO[Control.GetLabel(10)]</param>
                                    <param name="icon">$VAR[Image_DialogConfirm_10]</param>
                                    <param name="icon_bordersize">4</param>
                                    <param name="icon_withtext">true</param>
                                    <control type="button" id="9110">
                                        <include>defs_dialog_button</include>
                                        <onclick>SendClick(10)</onclick>
                                        <ondown condition="Control.IsVisible(12)">12</ondown>
                                        <include content="Animation_ConditionalFade">
                                            <param name="condition">Control.IsVisible(20)</param>
                                        </include>
                                    </control>
                                </include>
                            </control>

                            <control type="group">
                                <height>130</height>
                                <visible>!Control.IsVisible(10) + Control.IsVisible(11)</visible>
                                <include content="Dialog_Special_Button">
                                    <param name="id">9111</param>
                                    <param name="sublabel">$INFO[Control.GetLabel(11)]</param>
                                    <param name="icon">$VAR[Image_DialogConfirm_11]</param>
                                    <param name="icon_bordersize">4</param>
                                    <param name="icon_withtext">true</param>
                                    <control type="button" id="9111">
                                        <include>defs_dialog_button</include>
                                        <onclick>SendClick(11)</onclick>
                                        <ondown condition="Control.IsVisible(12)">12</ondown>
                                        <include content="Animation_ConditionalFade">
                                            <param name="condition">Control.IsVisible(20)</param>
                                        </include>
                                    </control>
                                </include>
                            </control>

                            <control type="group">
                                <height>130</height>
                                <visible>Control.IsVisible(12)</visible>
                                <include content="Dialog_Special_Button">
                                    <param name="id">9012</param>
                                    <param name="sublabel">$INFO[Control.GetLabel(12)]</param>
                                    <param name="icon">$VAR[Image_DialogConfirm_12]</param>
                                    <param name="icon_bordersize">4</param>
                                    <param name="icon_withtext">true</param>
                                    <control type="button" id="9012">
                                        <include>defs_dialog_button</include>
                                        <onclick>SendClick(12)</onclick>
                                        <onup condition="Control.IsVisible(10) + !Control.IsVisible(11)">10</onup>
                                        <onup condition="Control.IsVisible(11) + !Control.IsVisible(10)">11</onup>
                                        <onup condition="Control.IsVisible(11) + Control.IsVisible(10)">9200</onup>
                                    </control>
                                </include>
                            </control>
                        </control>
                    </control>
                </control>
            </control>
        </control>

    </controls>
</window>
