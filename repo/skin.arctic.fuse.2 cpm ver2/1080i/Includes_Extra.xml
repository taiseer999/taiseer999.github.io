<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<include name="ExtraOSD">
		<control type="group">
			<include>Animation_FadeIn</include>
			<include>Animation_FadeOut</include>
			<visible>!Window.IsVisible(DialogPlayerProcessInfo.xml)</visible>
			<left>0</left>
			<top>0</top>

	      <control type="group">
	         <visible>Window.IsVisible(VideoOSD.xml)</visible>!String.IsEmpty(Player.Art(clearart))
	         <visible>!Window.IsVisible(MusicOSD.xml)</visible>
	         <visible>!Window.IsVisible(VideoFullScreen.xml) | !Window.IsVisible(Custom_1141_OSD_Cast.xml)</visible>
	         <visible>!Window.IsVisible(VideoOSDBookmarks.xml)</visible>
	         <visible>!Window.IsVisible(Custom_1140_OSD_Playlist.xml)</visible>
				<control type="image">
				<visible>!String.IsEmpty(Player.Art(discart))</visible>
                <include content="Animation_SlideIn_Dialog">
                    <param name="posy">48</param>
                </include>
				<top>180</top>
					<left>1115</left>
					<width>450</width>
					<aspectratio>keep</aspectratio>
					<texture>$VAR[Image_Player_Clearart]</texture>
				</control>
				<control type="image">
				<visible>String.IsEmpty(Player.Art(discart))</visible>
                <include content="Animation_SlideIn_Dialog">
                    <param name="posy">48</param>
                </include>
				<top>180</top>
					<left>1380</left>
					<width>450</width>
					<aspectratio>keep</aspectratio>
					<texture>$VAR[Image_Player_Clearart]</texture>
				</control>
		  </control>

	      <control type="group">
	         <visible>Window.IsVisible(VideoOSD.xml)</visible>
	         <visible>!Window.IsVisible(MusicOSD.xml)</visible>
	         <visible>!Window.IsVisible(VideoFullScreen.xml) | !Window.IsVisible(Custom_1141_OSD_Cast.xml)</visible>
	         <visible>!Window.IsVisible(VideoOSDBookmarks.xml)</visible>
	         <visible>!Window.IsVisible(Custom_1140_OSD_Playlist.xml)</visible>
				<control type="image">
                <include content="Animation_SlideIn_Dialog">
                    <param name="posy">48</param>
                </include>
				<top>180</top>
					<left>1570</left>
					<width>270</width>
					<aspectratio>keep</aspectratio>
					<texture>$INFO[Player.Art(discart)]</texture>
				</control>
		  </control>

          <control type="group">
	         <visible>Window.IsVisible(VideoOSD.xml) + Skin.HasSetting(Furniture.EnableObject_Codecs)</visible>
	         <visible>!Skin.HasSetting(Furniture.EnableObject_CodecsText)</visible>
	         <visible>Window.IsVisible(VideoOSD.xml)</visible>
	         <visible>!Window.IsVisible(MusicOSD.xml)</visible>
	         <visible>!Window.IsVisible(VideoFullScreen.xml) | !Window.IsVisible(Custom_1141_OSD_Cast.xml)</visible>
	         <visible>!Window.IsVisible(VideoOSDBookmarks.xml)</visible>
	         <visible>!Window.IsVisible(Custom_1140_OSD_Playlist.xml)</visible>
	         <top>540</top>
			 <left>view_pad</left>
              <control type="grouplist">
                <top>20</top>
                <orientation>horizontal</orientation>
                <width>1000</width>
                <align>left</align>
                <itemgap>15</itemgap>
                <usecontrolcoords>true</usecontrolcoords>
                <control type="image">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>85</width>
                    <height>58</height>
                    <aspectratio align="left">keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">flags/colorful/other/3D.png</texture>
                    <visible>VideoPlayer.IsStereoscopic</visible>
                </control>
                <control type="image" id="78880">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>85</width>
                    <height>58</height>
                    <aspectratio align="left">keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">$VAR[Image_VideoPlayer_HDRCodec]</texture>
                    <visible>!String.IsEmpty(Control.GetLabel(78880))</visible>
                </control>
                <control type="image" id="78881">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>85</width>
                    <height>58</height>
                    <aspectratio align="left">keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">$VAR[Image_VideoPlayer_RipSource]</texture>
                    <visible>!String.IsEmpty(Control.GetLabel(78881))</visible>
                </control>
                <control type="image" id="78882">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>94</width>
                    <height>58</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">flags/colorful/resolution/$INFO[VideoPlayer.VideoResolution].png</texture>
                    <visible>!String.IsEmpty(Control.GetLabel(78882))</visible>
                </control>
                <control type="image" id="78883">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>85</width>
                    <height>58</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">flags/colorful/source/$INFO[VideoPlayer.VideoCodec].png</texture>
                    <visible>!String.IsEmpty(Control.GetLabel(78883))</visible>
                </control>
                <control type="image" id="788814">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>85</width>
                    <height>58</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">flags/colorful/aspectratio/$INFO[VideoPlayer.VideoAspect].png</texture>
                    <visible>!String.IsEmpty(VideoPlayer.VideoAspect)</visible>
                </control>
                <control type="group">
                    <width>85</width>
                    <height>58</height>
                    <centertop>49.7%</centertop>
                    <visible>!String.IsEmpty(Player.Process(VideoFPS)) + Integer.IsGreater(Player.Process(VideoFPS),0)</visible>
                    <control type="image">
                        <texture colordiffuse="panel_fg_100">flags/colorful/other/fps.png</texture>
                        <aspectratio align="center">keep</aspectratio>
                    </control>
                    <control type="label">
                        <height>24</height>
                        <bottom>8</bottom>
                        <textcolor>panel_fg_100</textcolor>
                        <font>font_hint</font>
                        <label>$INFO[Player.Process(VideoFPS)]</label>
                        <align>center</align>
                        <aligny>center</aligny>
                    </control>
                </control>
                <control type="image" id="78884">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>85</width>
                    <height>58</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">$VAR[Image_VideoPlayer_AudioCodec]</texture>
                    <visible>!String.IsEmpty(Control.GetLabel(78884))</visible>
                </control>
                <control type="image" id="78885">
                    <left>7</left>
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>72</width>
                    <height>48</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">$VAR[Image_VideoPlayer_AudioChannels]</texture>
                    <visible>!String.IsEmpty(Control.GetLabel(78885))</visible>
                </control>
                <control type="group">
					<width>85</width>
					<visible>!String.IsEmpty(VideoPlayer.AudioLanguage)</visible>
                   <control type="image" id="audioflag">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>85</width>
                    <height>58</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">flags/colorful/other/soun.png</texture>
                   </control>
				   <control type="image">
					<centertop>50%</centertop>
					<left>52</left>
					<width>24</width>
					<height>24</height>
					<aspectratio>keep</aspectratio>
					<texture fallback="flags/colorful/other/language/fallback.png">$INFO[VideoPlayer.AudioLanguage,flags/colorful/other/language/,.png]</texture>
				   </control>
                </control>
                <control type="group">
					<width>85</width>
					<visible>!String.IsEmpty(VideoPlayer.SubtitlesLanguage)</visible>
                   <control type="image" id="subtitleflag">
                   	<visible>VideoPlayer.SubtitlesEnabled</visible>
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>85</width>
                    <height>58</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">flags/colorful/other/subt.png</texture>
                   </control>
				   <control type="image">
					<centertop>50%</centertop>
					<left>52</left>
					<width>24</width>
					<height>24</height>
					<aspectratio>keep</aspectratio>
					<texture fallback="flags/colorful/language/other/fallback.png">$INFO[VideoPlayer.SubtitlesLanguage,flags/colorful/other/language/,.png]</texture>
					<visible>!String.IsEmpty(VideoPlayer.SubtitlesLanguage)</visible>
				   </control>
                   <control type="image" id="subtitleflag">
                   	<visible>!VideoPlayer.SubtitlesEnabled</visible>			
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>85</width>
                    <height>58</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="panel_fg_100">flags/colorful/other/subtd.png</texture>
                   </control>
                </control>
                <include content="Animation_SlideIn_Dialog">
                    <param name="posy">48</param>
                </include>
			</control>
		  </control>
		  
          <control type="group">
	         <visible>Window.IsVisible(VideoOSD.xml) + Skin.HasSetting(Furniture.EnableObject_CodecsText)</visible>
	         <visible>!Window.IsVisible(MusicOSD.xml)</visible>
	         <visible>!Window.IsVisible(VideoFullScreen.xml) | !Window.IsVisible(Custom_1141_OSD_Cast.xml)</visible>
	         <visible>!Window.IsVisible(VideoOSDBookmarks.xml)</visible>
	         <visible>!Window.IsVisible(Custom_1140_OSD_Playlist.xml)</visible>
	         <top>540</top>
			 <left>view_pad</left>
              <control type="grouplist">
                <top>20</top>
                <orientation>horizontal</orientation>
                <width>1200</width>
                <align>left</align>
                <itemgap>15</itemgap>
                <usecontrolcoords>true</usecontrolcoords>
                <control type="label">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <align>left</align>
                    <aligny>center</aligny>
                    <width>auto</width>
                    <font>font_tiny_bold</font>
                    <textcolor>main_fg_90</textcolor>
                    <label>[UPPERCASE]$VAR[VideoPlayer_HDRCodec1]$VAR[OSDItem_RipSource,  •  ,]$INFO[VideoPlayer.VideoResolution,  •  ,]$INFO[VideoPlayer.VideoCodec,  •  ,]$INFO[VideoPlayer.VideoAspect,  •  ,][CAPITALIZE]$INFO[Player.Process(VideoFPS),  •  ,  Fps][/CAPITALIZE]$VAR[AudioCodecVar2,  •  ,]$VAR[AudioChannelsVar,  •  ,]$INFO[VideoPlayer.AudioLanguage,  •  ,][/UPPERCASE]</label>
                </control>
                </control>
                <include content="Animation_SlideIn_Dialog">
                    <param name="posy">48</param>
                </include>
			</control>

            <control type="group">
             <visible>Window.IsVisible(MusicOSD.xml)</visible>
             <visible>!Skin.HasSetting(Furniture.EnableObject_CodecsText)</visible>
	         <top>540</top>
			 <left>view_pad</left>
              <control type="grouplist">
                <top>20</top>
                <orientation>horizontal</orientation>
                <width>1000</width>
                <align>left</align>
                <itemgap>20</itemgap>
                <usecontrolcoords>true</usecontrolcoords>
               <control type="image" id="9968">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>85</width>
                    <height>58</height>
                     <texture colordiffuse="panel_fg_100">$VAR[Image_VideoPlayer_AudioCodec]</texture>
                     <aspectratio align="left">keep</aspectratio>
                     <visible allowhiddenfocus="true">!String.IsEmpty(Control.GetLabel(9968))</visible>
                </control>
               <control type="image" id="9969">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>72</width>
                    <height>50</height>
                     <texture colordiffuse="panel_fg_100">$VAR[AudioChannelsVar,flags/colorful/channels/,.png]</texture>
                     <aspectratio align="right">keep</aspectratio>
                     <visible allowhiddenfocus="true">!String.IsEmpty(Control.GetLabel(9969))</visible>
                </control>
                 <control type="group">
                 <visible>!String.IsEmpty(MusicPlayer.BitRate)</visible>
                 <centertop>49.6%</centertop>
					<width>150</width>
                   <control type="image" id="bitrate">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>150</width>
                    <aspectratio>keep</aspectratio>
                    <texture>flags/colorful/audio/kb.png</texture>
                   </control>
	               <control type="label">
	                 <width>100</width>
	                 <left>-4</left>
	                 <align>center</align>
                     <textcolor>$VAR[ColorHighlight]</textcolor>
                     <font>font_main_bold</font>
					<label> $INFO[MusicPlayer.BitRate]</label>
				   </control>
                </control>
                 <control type="group">
                 <visible>!String.IsEmpty(MusicPlayer.BitsPerSample)</visible>
                 <centertop>49.6%</centertop>
					<width>150</width>
                   <control type="image" id="bitrate">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>150</width>
                    <aspectratio>keep</aspectratio>
                    <texture>flags/colorful/audio/bit.png</texture>
                   </control>
	               <control type="label">
	                 <width>100</width>
	                 <left>-4</left>
	                 <align>center</align>
                     <textcolor>$VAR[ColorHighlight]</textcolor>
                     <font>font_main_bold</font>
					<label> $INFO[MusicPlayer.BitsPerSample]</label>
				   </control>
                </control>
                <control type="group">
                <visible>!String.IsEmpty(MusicPlayer.SampleRate)</visible>
                 <centertop>49.6%</centertop>
					<width>150</width>
                   <control type="image" id="bitrate">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <width>150</width>
                    <aspectratio>keep</aspectratio>
                    <texture>flags/colorful/audio/khz.png</texture>
                   </control>
	               <control type="label">
	                 <width>100</width>
	                 <left>-4</left>
	                 <align>center</align>
                     <textcolor>$VAR[ColorHighlight]</textcolor>
                     <font>font_main_bold</font>
					<label> $INFO[MusicPlayer.SampleRate]</label>
				   </control>
                </control>
              </control>
		  </control>
              
          <control type="group">
             <visible>Window.IsVisible(MusicOSD.xml) + Skin.HasSetting(Furniture.EnableObject_CodecsText)</visible>
	         <top>540</top>
			 <left>view_pad</left>
              <control type="grouplist">
                <top>20</top>
                <orientation>horizontal</orientation>
                <width>1000</width>
                <align>left</align>
                <itemgap>20</itemgap>
                <usecontrolcoords>true</usecontrolcoords>
                <control type="Label">
                    <fadetime>100</fadetime>
                    <centertop>50%</centertop>
                    <align>left</align>
                    <aligny>center</aligny>
                    <width>auto</width>
                    <font>font_main_bold</font>
                    <textcolor>main_fg_90</textcolor>>
                    <label>[UPPERCASE]$VAR[AudioCodecVar2]$VAR[AudioChannelsVar,  •  ,]$INFO[MusicPlayer.BitRate,  •  ,  kb/s]$INFO[MusicPlayer.BitsPerSample,  •  ,  bits]$INFO[MusicPlayer.SampleRate,  •  ,  khz][/UPPERCASE]</label>
                </control>
                  <include content="Animation_SlideIn_Dialog">
                    <param name="posy">48</param>
                  </include>
              </control>
            </control>
		</control>
	</include>
</includes>