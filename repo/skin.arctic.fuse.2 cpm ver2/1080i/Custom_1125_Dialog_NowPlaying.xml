<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1125">
    <zorder>999</zorder>
    <visible>Player.HasMedia</visible>
    <visible>Skin.HasSetting(Furniture.EnableNowPlaying)</visible>
    <visible>!Window.IsActive(DialogNotification.xml)</visible>
    <visible>!Window.IsActive(DialogExtendedProgressBar.xml)</visible>
    <visible>!Window.IsActive(fullscreenvideo)</visible>
    <visible>!Window.IsActive(visualisation)</visible>
    <controls>

        <control type="progress" id="933">
            <height>1</height>
            <width>1</width>
            <left>-1000</left>
            <texturebg />
            <lefttexture />
            <midtexture />
            <righttexture />
            <info>Player.Progress</info>
            <visible>false</visible>
        </control>


        <include content="Furniture_Busy" condition="Skin.HasSetting(Furniture.EnableNowPlaying)">
            <param name="hasprogress">true</param>
            <param name="spinnervisible">!Window.IsVisible(DialogVolumeBar.xml) + !Window.IsActive(DialogBusy.xml)</param>
            <param name="icon">$VAR[Image_NowPlaying_PlayPause]</param>
            <param name="progress">Player.Progress</param>
            <param name="progress_id">933</param>
            <param name="minilabel">$VAR[Label_NowPlayingSubLabel]</param>
            <param name="mainlabel">$VAR[Label_NowPlayingTitle]</param>
            <param name="visible">!Window.IsActive(DialogNotification.xml) + ![Window.IsActive(fullscreenvideo) | Window.IsActive(visualisation)]</param>
            <param name="visible_condition">!$EXP[Exp_FurnitureBusy_AnimationCond_DialogNowPlaying]</param>
            <param name="windowopen_condition">!$EXP[Exp_FurnitureBusy_AnimationCond_DialogNowPlaying]</param>
        </include>


    </controls>
</window>