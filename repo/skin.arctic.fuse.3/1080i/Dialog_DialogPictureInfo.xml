<?xml version="1.0" encoding="UTF-8"?>
<includes>
    <include name="DialogPictureInfo">
        <param name="header">$INFO[ListItem.Label]</param>
        <param name="include_picture">DialogPictureInfo_Image</param>
        <param name="include_items">Object_Null</param>
        <param name="include_movement">Object_Null</param>
        <param name="dialog_size">Dimension_DialogFullMenu</param>
        <param name="dialog_right">520</param>
        <param name="include_itemline">false</param>
        <param name="itemline_haspath">true</param>
        <definition>
            <include>Part_Dim_Overlay</include>

            <control type="group">
                <include content="Part_Dialog_Backing">
                    <param name="dialog_size">$PARAM[dialog_size]</param>
                </include>

                <!-- Content -->
                <control type="group" id="8000">
                    <include>Size_Dialog_Pad</include>

                    <!-- Left -->
                    <control type="group">
                        <left>$PARAM[dialog_right]</left>
                        <include>Part_Panel</include>
                        <control type="group">
                            <include>Size_Group_Head</include>
                            <include content="Part_HeadText">
                                <param name="id">9999</param>
                                <param name="label">$PARAM[header]</param>
                            </include>
                            <include content="Part_ItemLine" condition="$PARAM[include_itemline]">
                                <param name="visible">true</param>
                                <param name="label">$PARAM[itemline]</param>
                                <param name="haspath">$PARAM[itemline_haspath]</param>
                            </include>
                            <include condition="![$PARAM[include_itemline]]">Part_Line</include>
                            <include>Part_CloseButton</include>
                        </control>
                        <control type="group">
                            <include>Size_Group_Body</include>
                            <include content="$PARAM[include_picture]">
                                <param name="icon">$PARAM[icon]</param>
                            </include>
                        </control>
                    </control>

                    <control type="group">
                        <!-- <include>Part_Panel</include> -->
                        <left>0</left>
                        <width>$PARAM[dialog_right]</width>
                        <control type="panel" id="5">
                            <left>0</left>
                            <right>0</right>
                            <top>14</top>
                            <bottom>20</bottom>
                            <include>Size_Dialog_Pad</include>
                            <onclick>RunScript(script.skinvariables,run_dialog=ok,heading=$INFO[Container(5).ListItem.Label],message=$INFO[Container(5).ListItem.Label2])</onclick>
                            <orientation>horizontal</orientation>
                            <orientation>vertical</orientation>
                            <itemlayout height="106">
                                <include>Layout_BasicMeta</include>
                            </itemlayout>
                            <focusedlayout height="106">
                                <include content="Layout_BasicMeta">
                                    <param name="selected">true</param>
                                </include>
                            </focusedlayout>
                            <include>$PARAM[include_items]</include>
                        </control>
                        <control type="grouplist">
                            <align>center</align>
                            <orientation>horizontal</orientation>
                            <itemgap>10</itemgap>
                            <bottom>10</bottom>
                            <height>20</height>
                            <include content="Part_Page_Indicator">
                                <param name="id">5</param>
                                <param name="page">1</param>
                            </include>
                            <include content="Part_Page_Indicator">
                                <param name="id">5</param>
                                <param name="page">2</param>
                            </include>
                            <include content="Part_Page_Indicator">
                                <param name="id">5</param>
                                <param name="page">3</param>
                            </include>
                            <include content="Part_Page_Indicator">
                                <param name="id">5</param>
                                <param name="page">4</param>
                            </include>
                        </control>
                    </control>
                </control>
            </control>
        </definition>
    </include>

    <include name="DialogPictureInfo_Image">
        <param name="icon">$INFO[ListItem.Icon]</param>
        <param name="diffuse">diffuse/landscape_w1140_h680.png</param>
        <definition>
            <include content="Part_Box_Outline">
                <include>Size_Dialog_Pad</include>
                <control type="image">
                    <aspectratio scalediffuse="false">scale</aspectratio>
                    <texture background="true" diffuse="$PARAM[diffuse]" colordiffuse="ff333333">$PARAM[icon]</texture>
                </control>
                <control type="image">
                    <aspectratio scalediffuse="false">keep</aspectratio>
                    <texture background="true" diffuse="$PARAM[diffuse]">$PARAM[icon]</texture>
                </control>
            </include>
        </definition>
    </include>

    <include name="DialogPictureInfo_Video">
        <include content="DialogPictureInfo_Image">
            <param name="icon">$INFO[Player.Icon]</param>
            <!-- <param name="diffuse">diffuse/square_w600_h600.png</param> -->
        </include>
    </include>
</includes>
