<?xml version="1.0" encoding="UTF-8"?>
<addon id="repository.easynewsx"
       name="EasyNews Repository"
       version="1.0.0"
       provider-name="Tetsuo">

    <extension point="xbmc.addon.repository">
        <dir>
            <!-- URLs must be a single line (no line breaks inside the tag). -->
            <info compressed="false">https://raw.githubusercontent.com/tetsuosoft/EasyNewsKodi/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/tetsuosoft/EasyNewsKodi/main/addons.xml.md5</checksum>
            <datadir zip="true">https://kodi.clientsite.co.uk/</datadir>
        </dir>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>EasyNews Kodi Repository</summary>
        <description>Repository for EasyNews addon</description>
        <platform>all</platform>
    </extension>

</addon>