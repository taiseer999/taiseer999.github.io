<?xml version="1.0" encoding="UTF-8"?>
<window>
    <defaultcontrol always="true">9000</defaultcontrol>
    <controls>
        <!-- Fullscreen dimmed background -->
        <control type="group">
            <control type="image">
                <left>0</left><top>0</top><width>1920</width><height>1080</height>
                <texture colordiffuse="FF0D0819">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
            </control>
            <control type="image">
                <left>0</left><top>0</top><width>1920</width><height>1080</height>
                <aspectratio>scale</aspectratio>
                <texture>$INFO[Window.Property(fanart)]</texture>
                <animation effect="fade" start="0" end="20" time="0" tween="sine">WindowOpen</animation>
            </control>
            <control type="image">
                <left>0</left><top>0</top><width>1920</width><height>1080</height>
                <texture colordiffuse="CC0D0819">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
            </control>
        </control>

        <!-- Centered card -->
        <control type="group">
            <animation effect="fade" end="100" time="220">WindowOpen</animation>
            <animation effect="slide" start="0,30" end="0,0" time="260" tween="cubic" easing="out">WindowOpen</animation>

            <!-- Card background -->
            <control type="image">
                <left>460</left><top>290</top><width>1000</width><height>500</height>
                <texture border="18" colordiffuse="F01A1332">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
            </control>

            <!-- Top gradient stripe - purple to cyan (Dex Hub brand) -->
            <control type="image">
                <left>460</left><top>290</top><width>1000</width><height>4</height>
                <texture colordiffuse="FF7C3AED">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
            </control>

            <!-- Dex Hub icon -->
            <control type="image">
                <left>500</left><top>330</top><width>80</width><height>80</height>
                <aspectratio>keep</aspectratio>
                <texture>special://home/addons/plugin.video.dexhub/resources/media/icon.png</texture>
            </control>

            <!-- Title / media name -->
            <control type="label">
                <left>600</left><top>335</top><width>820</width><height>40</height>
                <font>font13</font>
                <textcolor>FFFFFFFF</textcolor>
                <label>$INFO[Window.Property(title)]</label>
            </control>

            <!-- Year / type badge -->
            <control type="label">
                <left>600</left><top>380</top><width>820</width><height>28</height>
                <font>font10</font>
                <textcolor>FFB07CFF</textcolor>
                <label>$INFO[Window.Property(subtitle)]</label>
            </control>

            <!-- Divider -->
            <control type="image">
                <left>500</left><top>440</top><width>920</width><height>2</height>
                <texture colordiffuse="332A2040">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
            </control>

            <!-- Status line - big -->
            <control type="label">
                <left>500</left><top>475</top><width>920</width><height>50</height>
                <font>font14</font>
                <textcolor>FF33D8F7</textcolor>
                <align>center</align>
                <label>$INFO[Window.Property(status)]</label>
            </control>

            <!-- Secondary status - provider progress -->
            <control type="label">
                <left>500</left><top>540</top><width>920</width><height>32</height>
                <font>font11</font>
                <textcolor>FFB07CFF</textcolor>
                <align>center</align>
                <label>$INFO[Window.Property(sub_status)]</label>
            </control>

            <!-- Providers checked so far -->
            <control type="label">
                <left>500</left><top>590</top><width>920</width><height>28</height>
                <font>font10</font>
                <textcolor>FF8E7DB3</textcolor>
                <align>center</align>
                <label>$INFO[Window.Property(providers_line)]</label>
            </control>

            <!-- Progress bar -->
            <control type="image">
                <left>560</left><top>640</top><width>800</width><height>6</height>
                <texture border="3" colordiffuse="33FFFFFF">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
            </control>
            <control type="progress">
                <description>Provider progress</description>
                <left>560</left><top>640</top><width>800</width><height>6</height>
                <info>Window.Property(progress_pct)</info>
                <texturebg colordiffuse="00000000">special://home/addons/plugin.video.dexhub/resources/media/black.png</texturebg>
                <lefttexture colordiffuse="FF7C3AED">special://home/addons/plugin.video.dexhub/resources/media/black.png</lefttexture>
                <midtexture colordiffuse="FF7C3AED">special://home/addons/plugin.video.dexhub/resources/media/black.png</midtexture>
                <righttexture colordiffuse="FF33D8F7">special://home/addons/plugin.video.dexhub/resources/media/black.png</righttexture>
            </control>

            <!-- Results-count badge -->
            <control type="label">
                <left>500</left><top>675</top><width>920</width><height>30</height>
                <font>font11</font>
                <textcolor>FF33D8F7</textcolor>
                <align>center</align>
                <label>$INFO[Window.Property(results_line)]</label>
            </control>

            <!-- Cancel button at the bottom -->
            <control type="button" id="9000">
                <left>810</left><top>720</top><width>300</width><height>50</height>
                <font>font12</font>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <align>center</align>
                <aligny>center</aligny>
                <texturenofocus border="25" colordiffuse="66000000">special://home/addons/plugin.video.dexhub/resources/media/black.png</texturenofocus>
                <texturefocus border="25" colordiffuse="FF7C3AED">special://home/addons/plugin.video.dexhub/resources/media/black.png</texturefocus>
                <label>$INFO[Window.Property(cancel_label)]</label>
                <onclick>SendClick(9999,10)</onclick>
            </control>
        </control>
    </controls>
</window>
