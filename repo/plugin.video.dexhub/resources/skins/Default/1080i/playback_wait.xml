<?xml version="1.0" encoding="UTF-8"?>
<!--
  DexHub Playback Wait Screen  v6 — MODERN PREMIUM

  Design language:
    • Cinematic full-bleed fanart at 45% (up from 35%)
    • Left-to-right gradient: deep charcoal on left, transparent on right
    • Poster: 400×600 with 3-layer amber glow halo + dark matte card
    • Right panel: glassmorphism card (dark+blur effect via layered alpha)
      - Amber 3px top border
      - ClearLogo hero (900×190px) or bold title text
      - Meta chip row: year · type · ep  [PROVIDER]
      - Separator line
      - Plot (3 lines)
      - Status: "جاري التشغيل · CONNECTING" (large, cyan dot)
      - Progress bar: 8px neon amber fill over 8px dim track
      - 5-bar animated wave (12px tall)
      - Cancel hint
    • Control IDs unchanged from v5 — Python setImage/setLabel unchanged

  Control IDs:
    500  poster image           setImage()
    501  clearlogo image        setImage()
    502  fanart image           setImage()
    510  title label            setLabel() / setVisible()
    511  meta line              setLabel()
    512  plot textbox           setText()
    513  provider chip label    setLabel()
    520  provider chip group    setVisible()
    530  status label           static
    540  progress control       info=Window(10000).Property(dex.marquee_pct)
    541‥545 wave bars          colordiffuse=Window(10000).Property(dex.barN)
-->
<window type="dialog">
  <zorder>9</zorder>
  <controls>

    <!-- ═══ BACKGROUND STACK ═══════════════════════════════════════════════ -->

    <!-- 1. Base charcoal (prevents pure black flash) -->
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>1080</height>
      <texture colordiffuse="FF080614">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
    </control>

    <!-- 2. Fanart — full bleed, 45% opacity, fade-in 600ms -->
    <control type="image" id="502">
      <left>0</left><top>0</top><width>1920</width><height>1080</height>
      <aspectratio>scale</aspectratio>
      <texture background="true"
               fallback="special://home/addons/plugin.video.dexhub/resources/media/fanart.jpg">
      </texture>
      <animation effect="fade" start="0" end="45" time="600" tween="sine">WindowOpen</animation>
    </control>

    <!-- 3. Left half heavy vignette — makes poster area feel grounded -->
    <control type="image">
      <left>0</left><top>0</top><width>960</width><height>1080</height>
      <texture colordiffuse="CC080614">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
    </control>

    <!-- 4. Right-side lighter overlay — content stays readable -->
    <control type="image">
      <left>960</left><top>0</top><width>960</width><height>1080</height>
      <texture colordiffuse="AA080614">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
    </control>

    <!-- 5. Bottom fade — grounds the content -->
    <control type="image">
      <left>0</left><top>750</top><width>1920</width><height>330</height>
      <texture colordiffuse="DD080614">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
    </control>

    <!-- 6. Amber top accent bar (3px) -->
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>3</height>
      <texture colordiffuse="EEFFB347">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
    </control>

    <!-- ═══ CONTENT CARD (slides in from below, fades in) ═══════════════════ -->
    <control type="group">
      <animation effect="fade" start="0" end="100" time="320" tween="sine">WindowOpen</animation>
      <animation effect="slide" start="0,36" end="0,0"
                 time="380" tween="cubic" easing="out">WindowOpen</animation>
      <animation effect="fade" start="100" end="0" time="200">WindowClose</animation>

      <!-- ─── POSTER COLUMN (x=70..470) ───────────────────────────────────── -->
      <control type="group">
        <left>70</left><top>110</top>

        <!-- Outermost glow halo (largest, most transparent) -->
        <control type="image">
          <left>-20</left><top>-20</top><width>440</width><height>640</height>
          <texture border="20" colordiffuse="22FFB347">special://home/addons/plugin.video.dexhub/resources/media/circle.png</texture>
        </control>
        <!-- Mid glow halo -->
        <control type="image">
          <left>-10</left><top>-10</top><width>420</width><height>620</height>
          <texture border="14" colordiffuse="44FFB347">special://home/addons/plugin.video.dexhub/resources/media/circle.png</texture>
        </control>
        <!-- Inner amber outline -->
        <control type="image">
          <left>-4</left><top>-4</top><width>408</width><height>608</height>
          <texture border="8" colordiffuse="88FFB347">special://home/addons/plugin.video.dexhub/resources/media/circle.png</texture>
        </control>

        <!-- Dark card behind poster (deep navy) -->
        <control type="image">
          <left>0</left><top>0</top><width>400</width><height>600</height>
          <texture colordiffuse="FF141828">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
        </control>

        <!-- Poster image — id 500, set via setImage() -->
        <control type="image" id="500">
          <left>0</left><top>0</top><width>400</width><height>600</height>
          <aspectratio aligny="top" align="center">keep</aspectratio>
          <texture fallback="special://home/addons/plugin.video.dexhub/resources/media/default_video.png">
            special://home/addons/plugin.video.dexhub/resources/media/default_video.png
          </texture>
        </control>
      </control>

      <!-- ─── INFO PANEL (x=510..1880) ────────────────────────────────────── -->
      <control type="group">
        <left>510</left><top>100</top>

        <!-- Glassmorphism card background -->
        <control type="image">
          <left>0</left><top>0</top><width>1370</width><height>830</height>
          <texture border="24" colordiffuse="99101420">special://home/addons/plugin.video.dexhub/resources/media/circle.png</texture>
        </control>
        <!-- Card amber top border (3px) -->
        <control type="image">
          <left>0</left><top>0</top><width>1370</width><height>3</height>
          <texture colordiffuse="CCFFB347">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
        </control>

        <!-- Inner content group with padding -->
        <control type="group">
          <left>48</left><top>30</top>

          <!-- ── CLEARLOGO (hero title) — id 501 ─────────────────────────── -->
          <control type="image" id="501">
            <left>0</left><top>0</top><width>900</width><height>190</height>
            <aspectratio align="left" aligny="center">keep</aspectratio>
            <texture fallback=""></texture>
          </control>

          <!-- Title text fallback — id 510 (hidden when clearlogo shown) -->
          <control type="label" id="510">
            <left>0</left><top>36</top><width>1260</width><height>130</height>
            <font>font24</font>
            <textcolor>FFE8E8F0</textcolor>
            <shadowcolor>EE000000</shadowcolor>
            <wrapmultiline>true</wrapmultiline>
            <label></label>
          </control>

          <!-- ── META ROW: year · type · ep + provider chip ──────────────── -->
          <!-- Meta line — id 511 -->
          <control type="label" id="511">
            <left>0</left><top>202</top><width>820</width><height>30</height>
            <font>font12</font>
            <textcolor>FFFFB347</textcolor>
            <shadowcolor>CC000000</shadowcolor>
            <label></label>
          </control>

          <!-- Provider chip — group id 520, shown/hidden from Python -->
          <control type="group" id="520">
            <left>836</left><top>200</top>
            <!-- Outer amber ring -->
            <control type="image">
              <left>0</left><top>0</top><width>380</width><height>36</height>
              <texture border="16" colordiffuse="CCFFB347">special://home/addons/plugin.video.dexhub/resources/media/circle.png</texture>
            </control>
            <!-- Inner dark fill -->
            <control type="image">
              <left>2</left><top>2</top><width>376</width><height>32</height>
              <texture border="14" colordiffuse="FF0E1220">special://home/addons/plugin.video.dexhub/resources/media/circle.png</texture>
            </control>
            <!-- Provider text — id 513 -->
            <control type="label" id="513">
              <left>0</left><top>4</top><width>380</width><height>28</height>
              <font>font10</font>
              <textcolor>FFFFB347</textcolor>
              <align>center</align>
              <label></label>
            </control>
          </control>

          <!-- ── AMBER SEPARATOR ──────────────────────────────────────────── -->
          <control type="image">
            <left>0</left><top>244</top><width>1274</width><height>1</height>
            <texture colordiffuse="55FFB347">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
          </control>

          <!-- ── PLOT — id 512 ────────────────────────────────────────────── -->
          <control type="textbox" id="512">
            <left>0</left><top>256</top><width>1274</width><height>100</height>
            <font>font10</font>
            <textcolor>FFBEC3D0</textcolor>
            <shadowcolor>CC000000</shadowcolor>
            <label></label>
          </control>

          <!-- ── STATUS SECTION ───────────────────────────────────────────── -->
          <control type="group">
            <left>0</left><top>374</top>

            <!-- Cyan pulse dot -->
            <control type="image">
              <left>0</left><top>8</top><width>20</width><height>20</height>
              <texture border="8" colordiffuse="FF33D8F7">special://home/addons/plugin.video.dexhub/resources/media/circle.png</texture>
              <animation effect="pulse" start="70" end="100" time="1200"
                         loop="true" tween="sine">Visible</animation>
            </control>

            <!-- Status text — id 530 (static, no need to change) -->
            <control type="label" id="530">
              <left>36</left><top>0</top><width>900</width><height>40</height>
              <font>font13</font>
              <textcolor>FFE8E8F0</textcolor>
              <shadowcolor>EE000000</shadowcolor>
              <label>[B]جاري التشغيل  ·  CONNECTING[/B]</label>
            </control>

            <!-- ── PROGRESS BAR ─────────────────────────────────────────── -->
            <!-- Track (dim) -->
            <control type="image">
              <left>0</left><top>56</top><width>1274</width><height>8</height>
              <texture border="4" colordiffuse="2833D8F7">special://home/addons/plugin.video.dexhub/resources/media/circle.png</texture>
            </control>
            <!-- Fill glow layer (wider/softer) -->
            <control type="progress" id="540">
              <left>0</left><top>52</top><width>1274</width><height>16</height>
              <texturebg>special://home/addons/plugin.video.dexhub/resources/media/black.png</texturebg>
              <lefttexture>special://home/addons/plugin.video.dexhub/resources/media/black.png</lefttexture>
              <midtexture colordiffuse="55FFB347">special://home/addons/plugin.video.dexhub/resources/media/circle.png</midtexture>
              <righttexture>special://home/addons/plugin.video.dexhub/resources/media/black.png</righttexture>
              <overlaytexture>-</overlaytexture>
              <info>Window(10000).Property(dex.marquee_pct)</info>
            </control>
            <!-- Fill solid layer (sharp, on top) -->
            <control type="progress">
              <left>0</left><top>56</top><width>1274</width><height>8</height>
              <texturebg>special://home/addons/plugin.video.dexhub/resources/media/black.png</texturebg>
              <lefttexture>special://home/addons/plugin.video.dexhub/resources/media/black.png</lefttexture>
              <midtexture colordiffuse="FFFFB347">special://home/addons/plugin.video.dexhub/resources/media/circle.png</midtexture>
              <righttexture>special://home/addons/plugin.video.dexhub/resources/media/black.png</righttexture>
              <overlaytexture>-</overlaytexture>
              <info>Window(10000).Property(dex.marquee_pct)</info>
            </control>

            <!-- ── WAVE BARS (12px tall — more visible than 4px) ────────── -->
            <control type="group">
              <left>0</left><top>86</top>

              <control type="image" id="541">
                <left>0</left><top>0</top><width>80</width><height>12</height>
                <texture border="5" colordiffuse="$INFO[Window(10000).Property(dex.bar1)]">
                  special://home/addons/plugin.video.dexhub/resources/media/circle.png
                </texture>
              </control>
              <control type="image" id="542">
                <left>92</left><top>0</top><width>80</width><height>12</height>
                <texture border="5" colordiffuse="$INFO[Window(10000).Property(dex.bar2)]">
                  special://home/addons/plugin.video.dexhub/resources/media/circle.png
                </texture>
              </control>
              <control type="image" id="543">
                <left>184</left><top>0</top><width>80</width><height>12</height>
                <texture border="5" colordiffuse="$INFO[Window(10000).Property(dex.bar3)]">
                  special://home/addons/plugin.video.dexhub/resources/media/circle.png
                </texture>
              </control>
              <control type="image" id="544">
                <left>276</left><top>0</top><width>80</width><height>12</height>
                <texture border="5" colordiffuse="$INFO[Window(10000).Property(dex.bar4)]">
                  special://home/addons/plugin.video.dexhub/resources/media/circle.png
                </texture>
              </control>
              <control type="image" id="545">
                <left>368</left><top>0</top><width>80</width><height>12</height>
                <texture border="5" colordiffuse="$INFO[Window(10000).Property(dex.bar5)]">
                  special://home/addons/plugin.video.dexhub/resources/media/circle.png
                </texture>
              </control>

              <!-- Cancel hint -->
              <control type="label">
                <left>480</left><top>0</top><width>800</width><height>26</height>
                <font>font10</font>
                <textcolor>CC8E94A6</textcolor>
                <aligny>center</aligny>
                <label>اضغط رجوع للإلغاء  ·  PRESS BACK TO CANCEL</label>
              </control>
            </control><!-- end wave + hint -->

          </control><!-- end status section -->
        </control><!-- end inner padding group -->
      </control><!-- end info panel -->
    </control><!-- end content card -->

  </controls>
</window>
