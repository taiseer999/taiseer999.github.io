<settings>
  <category label="الإعدادات الأساسية">
    <setting id="resolution" type="enum" label="الدقة" values="1280x720|1920x1080|3840x2160" default="1" />
    <setting id="quality" type="enum" label="الجودة" values="منخفض|متوسط|عالي" default="1" />
    <setting id="save_path" type="folder" label="مجلد الحفظ" default="/storage/videos/" />
    <setting id="notifications" type="bool" label="إظهار إشعارات" default="true" />
  </category>

  <category label="أداء وترميز">
    <setting id="capture_mode" type="enum" label="مصدر الالتقاط" values="تلقائي - الشاشة الظاهرة|الشاشة الظاهرة KMS|طبقة framebuffer fb0" default="0" />
    <setting id="encoder" type="enum" label="المُرمِّز" values="H.264 libx264 (mp4)|HEVC libx265 (mp4)|VP9 (webm)" default="0" />
  </category>

  <category label="مشاركة">
    <setting id="enable_share" type="bool" label="تمكين زر المشاركة/QR" default="true" />
    <setting id="upload_backend" type="enum" label="موقع الرفع" values="Litterbox (72 ساعة)|Catbox" default="1" />
  </category>

  <category label="السجلات والتشخيص">
    <setting id="debug_log" type="bool" label="تفعيل سجل تفصيلي (Debug)" default="false" />
    <setting id="export_logs" type="action" label="تصدير حزمة السجلات" action="RunPlugin(plugin://plugin.video.screenrec/?action=export_logs)" />
    <setting id="open_logs" type="action" label="فتح مجلد السجلات" action="RunPlugin(plugin://plugin.video.screenrec/?action=open_logs)" />
  </category>

  <category label="حول الإضافة">
    <setting type="lsep" label="المطوّر: Meshal " />
    <setting type="lsep" label="Telegram: @i_Meshal" />
    <setting id="about" type="action" label="عن هذه الإضافة (حول)" action="RunPlugin(plugin://plugin.video.screenrec/?action=about)" />
  </category>
</settings>
