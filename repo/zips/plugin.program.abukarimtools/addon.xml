<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.program.abukarimtools"
       name="ABUKARIM TOOLS"
       version="1.0.8"
       provider-name="Custom">

  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>executable</provides>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">ABUKARIM TOOLS</summary>
    <description lang="en_GB">Unified plugin: Skin Installer, Skin Switcher, and Userdata Backup &amp; Restore.</description>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
    <platform>all</platform>
  </extension>

</addon>
