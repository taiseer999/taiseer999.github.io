<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.subtitles.dexworld" name="DexWorld AI Subtitles" version="5.0.0" provider-name="DexWorld">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.0"/>
    </requires>

    <extension point="xbmc.subtitle.module" library="service.py">
        <provides>subtitles</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <language>ar,en</language>
        <summary lang="ar">ترجمات عربية ذكية من مصادر متعددة مع ترجمة AI</summary>
        <summary lang="en">Smart subtitles with AI translation</summary>
        <description lang="ar">إضافة ترجمة عربية تدعم مزودات متعددة مع وسم واضح لنتائج AI.</description>
        <description lang="en">Subtitle addon with multiple providers and clear AI tagging.</description>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
