<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.portal"
       name="Portal"
       version="1.4.0"
       provider-name="Taiseer">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">

        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Portal Skin Selector</summary>
        <description>Select skins from Kodi or CoreELEC repositories</description>
        <platform>all</platform>
        
    </extension>

</addon>
