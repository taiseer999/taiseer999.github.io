<window type="dialog">
    <coordinates>
        <left>0</left>
        <top>0</top>
        <width>1920</width>
        <height>1080</height>
    </coordinates>
    <controls>

        <!-- Dim overlay -->
        <control type="image">
            <left>0</left><top>0</top>
            <width>1920</width><height>1080</height>
            <texture background="true">white.png</texture>
            <colordiffuse>D0000000</colordiffuse>
        </control>

        <!-- Card background -->
        <control type="image">
            <left>410</left><top>165</top>
            <width>1100</width><height>750</height>
            <texture background="true">white.png</texture>
            <colordiffuse>FF1A1A1A</colordiffuse>
        </control>

        <!-- Red top bar -->
        <control type="image">
            <left>410</left><top>165</top>
            <width>1100</width><height>8</height>
            <texture background="true">white.png</texture>
            <colordiffuse>FFED1C24</colordiffuse>
        </control>

        <!-- Title -->
        <control type="label">
            <left>410</left><top>195</top>
            <width>1100</width><height>60</height>
            <align>center</align>
            <font>font27</font>
            <textcolor>FFED1C24</textcolor>
            <label>Trakt Authorization</label>
        </control>

        <!-- QR white background -->
        <control type="image">
            <left>455</left><top>275</top>
            <width>420</width><height>420</height>
            <texture background="true">white.png</texture>
            <colordiffuse>FFFFFFFF</colordiffuse>
        </control>

        <!-- QR Code -->
        <control type="image">
            <left>465</left><top>285</top>
            <width>400</width><height>400</height>
            <aspectratio>stretch</aspectratio>
            <texture>$INFO[Window().Property(qr_image)]</texture>
        </control>

        <!-- Scan instruction -->
        <control type="label">
            <left>930</left><top>295</top>
            <width>530</width><height>40</height>
            <font>font12</font>
            <textcolor>FFAAAAAA</textcolor>
            <label>Scan QR code or visit:</label>
        </control>

        <!-- URL -->
        <control type="label">
            <left>930</left><top>350</top>
            <width>530</width><height>40</height>
            <font>font12</font>
            <textcolor>FFED1C24</textcolor>
            <label>https://trakt.tv/activate</label>
        </control>

        <!-- Divider -->
        <control type="image">
            <left>930</left><top>410</top>
            <width>530</width><height>2</height>
            <texture background="true">white.png</texture>
            <colordiffuse>44FFFFFF</colordiffuse>
        </control>

        <!-- Enter Code label -->
        <control type="label">
            <left>930</left><top>430</top>
            <width>530</width><height>40</height>
            <font>font12</font>
            <textcolor>FFAAAAAA</textcolor>
            <label>Enter this code:</label>
        </control>

        <!-- Code box border -->
        <control type="image">
            <left>930</left><top>480</top>
            <width>530</width><height>80</height>
            <texture background="true">white.png</texture>
            <colordiffuse>FFED1C24</colordiffuse>
        </control>

        <!-- Code box fill -->
        <control type="image">
            <left>934</left><top>484</top>
            <width>522</width><height>72</height>
            <texture background="true">white.png</texture>
            <colordiffuse>FF1A1A1A</colordiffuse>
        </control>

        <!-- User Code -->
        <control type="label">
            <left>930</left><top>484</top>
            <width>530</width><height>72</height>
            <align>center</align>
            <aligny>center</aligny>
            <font>font37</font>
            <textcolor>FFED1C24</textcolor>
            <label>$INFO[Window().Property(user_code)]</label>
        </control>

        <!-- Progress bar background -->
        <control type="image">
            <left>930</left><top>590</top>
            <width>530</width><height>8</height>
            <texture background="true">white.png</texture>
            <colordiffuse>44FFFFFF</colordiffuse>
        </control>

        <!-- Progress bar fill -->
        <control type="image">
            <left>930</left><top>590</top>
            <width>$INFO[Window().Property(progress_width)]</width><height>8</height>
            <texture background="true">white.png</texture>
            <colordiffuse>FFED1C24</colordiffuse>
        </control>

        <!-- Expires label -->
        <control type="label">
            <left>930</left><top>610</top>
            <width>530</width><height>35</height>
            <font>font_tiny</font>
            <textcolor>FF888888</textcolor>
            <label>$INFO[Window().Property(expires_label)]</label>
        </control>

        <!-- Cancel hint -->
        <control type="label">
            <left>410</left><top>870</top>
            <width>1100</width><height>35</height>
            <align>center</align>
            <font>font_tiny</font>
            <textcolor>FF666666</textcolor>
            <label>Press Back to cancel</label>
        </control>

    </controls>
</window>
