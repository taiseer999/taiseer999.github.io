<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1125">
    <zorder>999</zorder>
    <visible>Player.HasMedia</visible>
    <visible>Skin.HasSetting(Furniture.EnableNowPlaying)</visible>
    <visible>!Window.IsActive(DialogNotification.xml)</visible>
    <visible>!Window.IsActive(DialogExtendedProgressBar.xml)</visible>
    <controls>

        <control type="group">
            <include>Dimension_Bottombar</include>
            <control type="group">
                <include>Dimension_Furniture_Gutters</include>
                <include condition="Skin.HasSetting(Furniture.EnableNowPlaying)" content="Furniture_NowPlaying">
                    <param name="reposition">$EXP[Exp_HasActiveDialog]</param>
                </include>
            </control>
        </control>
    </controls>
</window>